---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

export interface Props {
    title?: string;
    backgroundImageUrl?: string;
}

const { title = "North Star", backgroundImageUrl } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <link rel="preload" as="image" href="/nslogo.svg" />

        <meta
            http-equiv="Cache-Control"
            content="public, max-age=31536000, immutable"
        />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Amaranth&family=Cormorant:wght@500;600&family=Geist:wght@300;400;500;600;700&family=Instrument+Serif:ital@1&display=swap"
            rel="stylesheet"
        />

        <style
            define:vars={{
                bgImageUrl: backgroundImageUrl
                    ? `url(${backgroundImageUrl})`
                    : "none",
            }}
        >
            :root {
                --offblack: #0f0e0c;
            }

            html,
            body {
                margin: 0;
                width: 100%;
                min-height: 100%;
                font-family: "Geist", sans-serif;
                scroll-behavior: smooth;
                background-color: var(--offblack);
                color: #fff;
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }

            /* Keep existing Tailwind black utilities slightly off-black site-wide. */
            .bg-black {
                background-color: var(--offblack) !important;
            }

            .from-black {
                --tw-gradient-from: rgb(10 10 10 / var(--tw-gradient-from-opacity, 1))
                    var(--tw-gradient-from-position) !important;
                --tw-gradient-to: rgb(10 10 10 / 0) var(--tw-gradient-to-position) !important;
                --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to) !important;
            }

            .via-black {
                --tw-gradient-via: rgb(10 10 10 / var(--tw-gradient-via-opacity, 1))
                    var(--tw-gradient-via-position) !important;
                --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-via),
                    var(--tw-gradient-to) !important;
            }

            .to-black {
                --tw-gradient-to: rgb(10 10 10 / var(--tw-gradient-to-opacity, 1))
                    var(--tw-gradient-to-position) !important;
            }

            /* Paper grain overlay */
            body::after {
                content: '';
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 9999;
                opacity: 0.038;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
                background-size: 160px;
                background-repeat: repeat;
            }

            .layout-container {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                background-image: var(--bgImageUrl);
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
            }

            .main-content {
                flex-grow: 1;
                padding-top: calc(env(safe-area-inset-top) + 0.5rem);
            }

            @media (min-width: 1024px) {
                .main-content {
                    padding-top: 5.5rem;
                }

                section[id],
                div[id] {
                    scroll-margin-top: 5.5rem;
                }
            }

            /* Darken background images on mobile for better text contrast */
            @media (max-width: 768px) {
                .mobile-bg-darken {
                    background-color: rgba(0, 0, 0, 0.85) !important;
                }
            }
        </style>
    </head>
    <body
        class="bg-background text-foreground antialiased selection:bg-white/20"
    >
        <div id="scroll-progress" style="position:fixed;top:0;left:0;height:2px;width:0%;background:rgba(255,255,255,0.45);z-index:99999;pointer-events:none;"></div>
        <script is:inline>
          (function() {
            var bar = document.getElementById('scroll-progress');
            window.addEventListener('scroll', function() {
              var scrolled = document.documentElement.scrollTop || document.body.scrollTop;
              var total = document.documentElement.scrollHeight - document.documentElement.clientHeight;
              bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
            }, { passive: true });
          })();
        </script>
        <div class="layout-container relative">
            <Navbar />
            {
                backgroundImageUrl && (
                    <div class="fixed inset-0 bg-black/80 backdrop-blur-[2px] pointer-events-none -z-10 mobile-bg-darken" />
                )
            }

            <div class="main-content relative z-10">
                <slot />
            </div>
            <Footer />
        </div>
    </body>
</html>
