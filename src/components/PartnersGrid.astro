---
const partners = [
  { src: '/partnerships/workedwith/29.png', alt: 'Hugging Face', url: 'https://huggingface.co/' },
  { src: '/partnerships/workedwith/10.svg', alt: 'ElevenLabs', url: 'https://elevenlabs.io/' },
  { src: '/partnerships/workedwith/15.svg', alt: 'Lovable', url: 'https://lovable.dev/' },
  { src: '/partnerships/workedwith/27.png', alt: 'European AI Office', url: 'https://digital-strategy.ec.europa.eu/en/policies/ai-office' },
  { src: '/partnerships/workedwith/30.png', alt: 'LeRobot', url: 'https://huggingface.co/lerobot' },
  { src: '/partnerships/workedwith/14.png', alt: 'Karel de Grote Hogeschool', url: 'https://www.kdg.be/' },
  { src: '/partnerships/workedwith/13.png', alt: 'iMagineLab', url: 'https://imaginelab.club/' },
  { src: '/partnerships/workedwith/16.png', alt: 'Nerdlab', url: 'https://nerdlab.be/' },
  { src: '/partnerships/workedwith/8.png', alt: 'Dwengo', url: 'https://www.dwengo.org/' },
  { src: '/partnerships/workedwith/4.png', alt: 'Brubotics', url: 'https://brubotics.eu/' },
  { src: '/partnerships/workedwith/3.png', alt: 'WeSTEM', url: 'https://www.westem.eu/' },
  { src: '/tectonic/tectonic.jpeg', alt: 'Tectonic', url: 'https://tectonicconf.eu/' },
  { src: '/partnerships/workedwith/5.png', alt: 'Campus 19', url: 'https://campus19.be/' },
  { src: '/partnerships/workedwith/9.png', alt: 'E6K', url: 'https://www.e6k.be/' },
  { src: '/partnerships/workedwith/7.png', alt: 'Creative STEM', url: 'https://decreatievestem.be/' },
  { src: '/partnerships/workedwith/22.png', alt: 'WAT', url: 'https://www.wat.com/' },
  { src: '/partnerships/workedwith/26.png', alt: 'Young Engineers', url: 'https://liegeville.youngengineers.org/' },
  { src: '/partnerships/workedwith/28.png', alt: 'La Grand Poste', url: 'https://www.lagrandposte.be/' },
  { src: '/partnerships/workedwith/24.png', alt: 'Wintercircus', url: 'https://www.wintercircus.be/' },
  { src: '/partnerships/workedwith/21.png', alt: 'The Beacon', url: 'https://thebeacon.eu/' },
  { src: '/partnerships/workedwith/12.png', alt: 'AP Hogeschool', url: 'https://www.ap.be/' },
];

const supporters = [
  { src: '/partnerships/workedwith/17.png', alt: 'Port of Antwerp-Bruges', url: 'https://www.portofantwerpbruges.com/en' },
  { src: '/partnerships/logos/2.png', alt: 'Brucon', url: 'https://www.brucon.org/' },
  { src: '/partnerships/logos/1.png', alt: 'Autodiscovery', url: 'https://autodiscovery.eu/' },
];
---

<section class="partners-grid-section">
  <div class="partners-grid-inner">
    <div class="partners-grid-header" data-reveal>
      <h2 class="partners-grid-title">We ♥</h2>
    </div>

    <div class="partners-grid-supporters" data-reveal data-reveal-delay="1">
      {supporters.map((s) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="partners-grid-supporter">
          <img src={s.src} alt={s.alt} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>

    <p class="partners-grid-friends-label" data-reveal>Our friends</p>

    <div class="partners-grid" data-reveal data-reveal-delay="2">
      {partners.map((p) => (
        <a href={p.url} target="_blank" rel="noopener noreferrer" class="partners-grid-item">
          <img src={p.src} alt={p.alt} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .partners-grid-section {
    padding: clamp(5rem, 12vh, 9rem) 0 clamp(4rem, 8vh, 7rem);
  }

  .partners-grid-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .partners-grid-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .partners-grid-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 400;
    color: rgba(255,255,255,0.88);
    line-height: 1.1;
  }

  .partners-grid-friends-label {
    margin: 0 0 2rem;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    color: rgba(255,255,255,0.72);
    text-align: center;
    line-height: 1.1;
  }

  .partners-grid-supporters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .partners-grid-supporter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(100px, 12vw, 140px);
    height: clamp(40px, 5vw, 52px);
    opacity: 0.72;
    transition: opacity 300ms ease;
  }

  .partners-grid-supporter:hover {
    opacity: 1;
  }

  .partners-grid-supporter img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    margin: 0 auto;
  }

  .partners-grid-item {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3 / 2;
    padding: 1rem;
    border: 1px solid rgba(255,255,255,0.04);
    margin: -0.5px;
    transition: background 300ms ease;
  }

  .partners-grid-item:hover {
    background: rgba(255,255,255,0.03);
  }

  .partners-grid-item img {
    max-width: 80%;
    max-height: 70%;
    object-fit: contain;
    display: block;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0.5;
    transition: filter 400ms ease, opacity 400ms ease;
  }

  .partners-grid-item:hover img {
    filter: grayscale(0%) brightness(1);
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .partners-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .partners-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .partners-grid-item {
      padding: 0.65rem;
    }

    .partners-grid-supporters {
      gap: 1.5rem;
    }
  }
</style>
