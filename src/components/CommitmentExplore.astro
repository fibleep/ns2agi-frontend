---
import { ArrowRight } from "lucide-react";
import { commitmentRoutes } from "../lib/commitment-routes";

interface Props {
  currentId?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
}

const {
  currentId,
  eyebrow = "Explore More",
  title = "See the other commitments",
  description = "Each commitment has its own operating logic, but they compound when they are connected.",
} = Astro.props;

const items = currentId
  ? commitmentRoutes.filter((item) => item.id !== currentId)
  : commitmentRoutes;
---

<section class="container mx-auto px-6 mt-24">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-10">
      <h2 class="text-3xl md:text-5xl text-white leading-tight">{title}</h2>
      <p class="mt-4 text-sm md:text-base text-white/62 leading-relaxed">{description}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        items.map((item) => (
          <a
            href={item.href}
            class="group rounded-[26px] border border-white/10 bg-white/[0.03] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-white/18 hover:bg-white/[0.05]"
          >
            <p class="text-[11px] uppercase tracking-[0.22em] text-white/45 mb-3">{item.index}</p>
            <h3 class="text-2xl text-white mb-3">{item.label}</h3>
            <p class="text-sm leading-relaxed text-white/66 min-h-[4.5rem]">{item.summary}</p>
            <div class="mt-5 inline-flex items-center gap-2 text-sm text-white/80 transition-colors group-hover:text-white">
              Open commitment <ArrowRight className="w-4 h-4" />
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
