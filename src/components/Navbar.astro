---
import {
    Briefcase,
    Heart,
    Info,
    Mail,
} from "lucide-react";

const currentPath = Astro.url.pathname;

const desktopNavLinks = [
    {
        name: "DONATE",
        href: "https://weglow.world/o/northstaragi/c/VRN975Y6",
        external: true,
    },
    { name: "COLLABORATE", href: "/work-with-us" },
    { name: "ABOUT", href: "/about" },
    { name: "CONTACT", href: "/contact" },
];

const mobileNavLinks = [
    {
        name: "Donate",
        href: "https://weglow.world/o/northstaragi/c/VRN975Y6",
        icon: Heart,
        external: true,
    },
    {
        name: "Collaborate",
        href: "/work-with-us",
        icon: Briefcase,
        external: false,
    },
    { name: "About", href: "/about", icon: Info, external: false },
    { name: "Contact", href: "/contact", icon: Mail, external: false },
];

const isActivePath = (href: string) => {
    if (href === "/") return currentPath === "/";
    return currentPath === href || currentPath.startsWith(`${href}/`);
};

---

<header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
    id="main-header"
>
    <div
        class="absolute inset-0 bg-black/50 backdrop-blur-xl transition-opacity duration-300"
        id="header-bg"
    >
    </div>
    <div class="container mx-auto px-6 h-20 relative z-10">
        <div class="flex items-center justify-between h-full">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 group">
                <img
                    src="/nslogo.svg"
                    alt="North Star AGI"
                    class="h-10 w-auto"
                />
                <span
                    class="font-bold text-white tracking-wider group-hover:text-white/80 transition-colors"
                    >NORTH STAR</span
                >
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-8">
                {
                    desktopNavLinks.map((link) => (
                        <a
                            href={link.href}
                            target={link.external ? "_blank" : "_self"}
                            rel={link.external ? "noopener noreferrer" : ""}
                            class="text-sm font-medium text-white/80 hover:text-white transition-colors tracking-wide py-2"
                        >
                            {link.name}
                        </a>
                    ))
                }
            </nav>

            <div class="w-6 h-6 lg:hidden" aria-hidden="true"></div>
        </div>
    </div>
</header>

<div class="fixed bottom-0 left-0 right-0 z-50 lg:hidden pointer-events-none">
    <div
        class="pointer-events-auto mobile-bottom-nav relative mx-2 mb-2 rounded-2xl border border-white/10 bg-black/90 backdrop-blur-xl shadow-[0_-8px_32px_rgba(0,0,0,0.35)]"
    >
        <nav
            class="grid grid-cols-4 gap-1 px-2 pt-2"
            style="padding-bottom: calc(env(safe-area-inset-bottom) + 0.5rem);"
        >
            {
                mobileNavLinks.map((link) => {
                    const Icon = link.icon;
                    const isActive = isActivePath(link.href);

                    return (
                        <a
                            href={link.href}
                            target={link.external ? "_blank" : "_self"}
                            rel={link.external ? "noopener noreferrer" : ""}
                            class={`flex flex-col items-center justify-center gap-1 rounded-xl px-2 py-2 text-[10px] leading-tight font-semibold tracking-wide text-center transition-colors ${
                                isActive
                                    ? "bg-white/10 text-white"
                                    : "text-white/55 hover:text-white/80 hover:bg-white/5"
                            }`}
                        >
                            <Icon className="w-5 h-5" />
                            <span>{link.name}</span>
                        </a>
                    );
                })
            }
        </nav>
    </div>
</div>
