---
import Layout from "../layouts/Layout.astro";
import { commitmentRoutes } from "../lib/commitment-routes";

interface Props {
  currentId: "events" | "education" | "engineering" | "ecosystem";
  title: string;
}

const { currentId, title } = Astro.props;
---

<Layout title={`${title} | North Star`}>
  <div class="cp-layout">
    <aside class="cp-sidebar">
      <a href="/" class="cp-sidebar-logo" aria-label="Home">
        <img src="/nsstar-clean.svg" alt="" class="cp-sidebar-star" />
      </a>
      <div class="cp-sidebar-section-label">Commitments</div>
      <nav class="cp-sidebar-nav" aria-label="Commitments">
        {commitmentRoutes.map((route) => (
          <a
            href={route.href}
            class:list={["cp-nav-item", route.id === currentId && "cp-nav-item-active"]}
          >
            <span class="cp-nav-index">{route.index}</span>
            <span class="cp-nav-label">{route.label}</span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- Mobile commitment scroll nav -->
    <nav class="cp-mobile-nav" aria-label="Commitments">
      <div class="cp-mobile-scroll">
        {commitmentRoutes.map((route) => (
          <a
            href={route.href}
            class:list={["cp-mobile-tab", route.id === currentId && "cp-mobile-tab-active"]}
          >
            {route.label}
          </a>
        ))}
      </div>
    </nav>

    <main class="cp-main">
      <slot />
    </main>
  </div>

</Layout>

<style is:global>
  /* ── Layout shell ── */
  .cp-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    min-height: 100dvh;
  }

  /* ── Sidebar ── */
  .cp-sidebar {
    position: sticky;
    top: 0;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: clamp(4.5rem, 8vh, 6rem) 1rem 2rem 1.25rem;
    border-right: 1px solid rgba(255, 255, 255, 0.055);
  }

  .cp-sidebar-logo { display: block; }
  .cp-sidebar-star {
    width: 22px;
    height: auto;
    opacity: 0.5;
    transition: opacity 200ms ease;
    display: block;
  }
  .cp-sidebar-logo:hover .cp-sidebar-star { opacity: 0.9; }

  .cp-sidebar-section-label {
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    padding-left: 0.1rem;
    margin-top: -0.5rem;
  }

  .cp-sidebar-nav { display: flex; flex-direction: column; gap: 0; }

  .cp-nav-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.52rem 0.5rem;
    border-radius: 0.4rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.3);
    border-left: 2px solid transparent;
    transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
    margin-left: -2px;
  }
  .cp-nav-item:hover {
    color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.03);
    border-left-color: rgba(255, 255, 255, 0.15);
  }
  .cp-nav-item-active {
    color: rgba(255, 255, 255, 0.9);
    border-left-color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.04);
  }

  .cp-nav-index {
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.18);
    width: 1.3rem;
    flex-shrink: 0;
    transition: color 140ms ease;
  }
  .cp-nav-item-active .cp-nav-index { color: rgba(255, 255, 255, 0.35); }

  .cp-nav-label {
    font-family: "Geist", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.015em;
  }

  /* ── Main content ── */
  .cp-main {
    padding: clamp(4.5rem, 8vh, 6rem) clamp(2rem, 5vw, 5rem) 6rem;
    max-width: 860px;
  }

  /* ── Content primitives ── */
  .cp-eyebrow {
    font-family: "Geist", sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin: 0 0 1.5rem;
  }

  .cp-headline {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.08;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 1.6rem;
  }

  .cp-lead {
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.92rem, 1.1vw, 1.05rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.48);
    margin: 0 0 3rem;
    max-width: 60ch;
    font-weight: 400;
  }

  /* ── Stats ── */
  .cp-stats {
    display: flex;
    gap: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    margin-bottom: 3.5rem;
  }

  .cp-stat {
    flex: 1;
    padding: 1.6rem 1.2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }
  .cp-stat:last-child { border-right: none; }

  .cp-stat-number {
    font-family: "Geist", sans-serif;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 0.3rem;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .cp-stat-label {
    font-family: "Geist", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Sections ── */
  .cp-section { margin-bottom: 3rem; }

  .cp-section-label {
    font-family: "Geist", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.26);
    margin: 0 0 1.1rem;
  }

  .cp-body {
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.92rem, 1.1vw, 1.02rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.48);
    margin: 0 0 0.9rem;
    max-width: 62ch;
    font-weight: 400;
  }

  .cp-link {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    transition: color 180ms ease, border-color 180ms ease;
  }
  .cp-link:hover { color: rgba(255, 255, 255, 0.95); border-color: rgba(255, 255, 255, 0.5); }

  /* ── Formats — horizontal list rows ── */
  .cp-format-rows {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .cp-format-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    gap: 2rem;
  }

  .cp-format-cat {
    font-family: "Geist", sans-serif;
    font-size: 0.76rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.78);
    white-space: nowrap;
    min-width: 7.5rem;
    letter-spacing: 0.02em;
  }

  .cp-format-items {
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.82rem, 0.95vw, 0.92rem);
    color: rgba(255, 255, 255, 0.35);
    text-align: right;
    line-height: 1.6;
    font-weight: 400;
  }

  /* ── Gallery — asymmetric mosaic ── */
  .cp-gallery {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 200px 200px;
    gap: 0.45rem;
  }

  /* Each img is wrapped in a clip container generated via :has or we clip on the img itself */
  .cp-gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.6rem;
    display: block;
    filter: brightness(0.78) saturate(0.68);
    transition: filter 500ms ease;
    overflow: hidden;
  }
  .cp-gallery-img:hover { filter: brightness(0.96) saturate(1.05); }

  .cp-gallery-img:nth-child(1) { grid-column: 1 / 3; grid-row: 1; }
  .cp-gallery-img:nth-child(2) { grid-column: 3; grid-row: 1 / 3; }
  .cp-gallery-img:nth-child(3) { grid-column: 1; grid-row: 2; }
  .cp-gallery-img:nth-child(4) { grid-column: 2; grid-row: 2; }

  /* ── Pillars (used in other pages) ── */
  .cp-pillars { display: flex; flex-direction: column; gap: 0.4rem; }

  .cp-pillar {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 0.75rem;
    padding: 1.2rem 1.3rem;
  }

  .cp-pillar-title {
    font-family: "Geist", sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 0.5rem;
  }

  .cp-pillar-body {
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.42);
    margin: 0;
    font-weight: 400;
  }

  /* ── Projects grid (used in other pages) ── */
  .cp-projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem;
  }

  .cp-project-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 0.75rem;
    padding: 1.2rem 1.3rem;
    text-decoration: none;
    display: block;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .cp-project-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.02);
  }

  .cp-project-name {
    font-family: "Geist", sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 0.4rem;
  }

  .cp-project-desc {
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.82rem, 0.95vw, 0.92rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.38);
    margin: 0;
    font-weight: 400;
  }

  /* ── Formats grid (legacy, kept for other pages) ── */
  .cp-formats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
  }

  .cp-format-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 0.75rem;
    padding: 1.1rem;
  }

  .cp-format-title {
    font-family: "Geist", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 0.7rem;
    letter-spacing: 0.04em;
  }

  .cp-format-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cp-format-list li {
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.4;
  }

  /* ── CTA row ── */
  .cp-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .cp-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1.2rem;
    background: #fff;
    color: #0f0e0c;
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 999px;
    text-decoration: none;
    transition: background 180ms ease;
  }
  .cp-cta-primary:hover { background: rgba(255, 255, 255, 0.88); }

  .cp-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.62);
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 999px;
    text-decoration: none;
    transition: border-color 180ms ease, color 180ms ease;
  }
  .cp-cta-secondary:hover {
    border-color: rgba(255, 255, 255, 0.32);
    color: rgba(255, 255, 255, 0.92);
  }

  /* ── Prose flow ── */
  .cp-prose .cp-body {
    margin-bottom: 1.5rem;
  }
  .cp-prose .cp-body:last-child {
    margin-bottom: 0;
  }

  /* ── Numbers row (soft, no cell dividers) ── */
  .cp-numbers {
    display: flex;
    gap: 3rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    margin: 2.5rem 0;
  }

  .cp-number-value {
    font-family: "Geist", sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.88);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 0.35rem;
  }

  .cp-number-label {
    font-family: "Geist", sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.26);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Horizontal rule ── */
  .cp-rule {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin: 2.5rem 0;
  }

  /* ── Entrance animations ── */
  @keyframes cp-fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .cp-eyebrow  { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0ms; }
    .cp-headline { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 55ms; }
    .cp-lead     { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 110ms; }
    .cp-stats    { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 165ms; }
    .cp-numbers  { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 165ms; }
    .cp-section  { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 200ms; }
    .cp-cta-row  { animation: cp-fade-up 480ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 240ms; }

    .cp-nav-item:nth-child(1) { animation: cp-fade-up 380ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 80ms; }
    .cp-nav-item:nth-child(2) { animation: cp-fade-up 380ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 120ms; }
    .cp-nav-item:nth-child(3) { animation: cp-fade-up 380ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 160ms; }
    .cp-nav-item:nth-child(4) { animation: cp-fade-up 380ms cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 200ms; }
  }

  /* ── Mobile commitment nav ── */
  .cp-mobile-nav {
    display: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cp-layout {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }

    .cp-sidebar { display: none; }

    .cp-mobile-nav {
      display: block;
      position: sticky;
      top: 0;
      z-index: 40;
      background: rgba(15, 14, 12, 0.92);
      backdrop-filter: blur(20px) saturate(140%);
      -webkit-backdrop-filter: blur(20px) saturate(140%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .cp-mobile-scroll {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 0.55rem 0.75rem;
      gap: 0.15rem;
    }
    .cp-mobile-scroll::-webkit-scrollbar { display: none; }

    .cp-mobile-tab {
      flex-shrink: 0;
      padding: 0.4rem 0.85rem;
      border-radius: 0.75rem;
      font-family: "Geist", sans-serif;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.38);
      text-decoration: none;
      transition: color 180ms ease, background 180ms ease;
      touch-action: manipulation;
    }
    .cp-mobile-tab:hover {
      color: rgba(255, 255, 255, 0.65);
    }
    .cp-mobile-tab-active {
      color: rgba(255, 255, 255, 0.92);
      background: rgba(255, 255, 255, 0.08);
    }

    .cp-main {
      padding: 1.5rem 1.25rem 3rem;
      max-width: 100%;
    }

    /* Gallery: 2-column on mobile */
    .cp-gallery {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 130px 130px 130px;
    }
    .cp-gallery-img:nth-child(1) { grid-column: 1 / 3; grid-row: 1; }
    .cp-gallery-img:nth-child(2) { grid-column: 1; grid-row: 2; }
    .cp-gallery-img:nth-child(3) { grid-column: 2; grid-row: 2; }
    .cp-gallery-img:nth-child(4) { grid-column: 1 / 3; grid-row: 3; }

    .cp-formats-grid { grid-template-columns: 1fr; }
    .cp-projects-grid { grid-template-columns: 1fr; }

    .cp-format-row {
      flex-direction: column;
      gap: 0.35rem;
      padding: 0.85rem 0;
    }
    .cp-format-items { text-align: left; }

    .cp-numbers {
      gap: 1.5rem;
      flex-wrap: wrap;
    }
  }
</style>
