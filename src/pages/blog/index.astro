---
import Layout from "../../layouts/Layout.astro";
import { blogPosts } from "../../lib/blog-posts";
import { ArrowRight } from "lucide-react";

const featured = blogPosts[0];
const rest = blogPosts.slice(1);
---

<Layout title="Blog | North Star">

  <main class="blog-index">

    <!-- Header -->
    <header class="blog-header" data-reveal>
      <h1 class="blog-header-title">Blog</h1>
    </header>

    <!-- Featured post -->
    <a href={`/blog/${featured.slug}`} class="blog-featured" data-reveal>
      <div class="blog-featured-img-wrap">
        <img src={featured.thumbnail} alt="" class="blog-featured-img" loading="eager" />
      </div>
      <div class="blog-featured-text">
        <p class="blog-card-meta">
          {featured.author}&nbsp;&middot;&nbsp;{featured.date}&nbsp;&middot;&nbsp;{featured.readTime}
        </p>
        <h2 class="blog-featured-title">{featured.title}</h2>
        <p class="blog-featured-excerpt">{featured.excerpt}</p>
        <span class="blog-card-cta">
          Read <ArrowRight className="w-3.5 h-3.5" />
        </span>
      </div>
    </a>

    <!-- Rest of posts -->
    {rest.length > 0 && (
      <div class="blog-grid">
        {rest.map((post, i) => (
          <a
            href={`/blog/${post.slug}`}
            class="blog-card"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <div class="blog-card-img-wrap">
              <img src={post.thumbnail} alt="" class="blog-card-img" loading="lazy" />
            </div>
            <div class="blog-card-body">
              <p class="blog-card-meta">
                {post.author}&nbsp;&middot;&nbsp;{post.date}&nbsp;&middot;&nbsp;{post.readTime}
              </p>
              <h3 class="blog-card-title">{post.title}</h3>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <span class="blog-card-cta">
                Read <ArrowRight className="w-3 h-3" />
              </span>
            </div>
          </a>
        ))}
      </div>
    )}

  </main>

</Layout>

<style is:global>

  .blog-index {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
  }

  /* ── Header ── */
  .blog-header {
    padding: clamp(8rem, 18vh, 14rem) 0 clamp(2rem, 4vh, 3rem);
    text-align: center;
  }

  .blog-header-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.05;
  }

  /* ── Featured ── */
  .blog-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.2rem, 2.5vw, 2rem);
    text-decoration: none;
    padding: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    transition: border-color 300ms ease, background 300ms ease;
    margin-bottom: clamp(1.5rem, 3vh, 2.5rem);
  }

  .blog-featured:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.02);
  }

  .blog-featured-img-wrap {
    border-radius: 0.5rem;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .blog-featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85) saturate(0.9);
    transition: filter 400ms ease, transform 500ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }

  .blog-featured:hover .blog-featured-img {
    filter: brightness(1) saturate(1);
    transform: scale(1.02);
  }

  .blog-featured-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }

  .blog-featured-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.15;
    transition: color 250ms ease;
  }

  .blog-featured:hover .blog-featured-title {
    color: rgba(255, 255, 255, 1);
  }

  .blog-featured-excerpt {
    margin: 0;
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.82rem, 1vw, 0.92rem);
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.6;
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .blog-featured {
      grid-template-columns: 1fr;
    }
  }

  /* ── Card grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
    padding-bottom: clamp(3rem, 6vh, 5rem);
  }

  @media (max-width: 520px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-card {
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color 300ms ease, background 300ms ease;
  }

  .blog-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.02);
  }

  .blog-card-img-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85) saturate(0.9);
    transition: filter 400ms ease, transform 500ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }

  .blog-card:hover .blog-card-img {
    filter: brightness(1) saturate(1);
    transform: scale(1.02);
  }

  .blog-card-body {
    padding: clamp(0.8rem, 1.5vw, 1.2rem);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  /* ── Shared card elements ── */
  .blog-card-meta {
    margin: 0;
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.04em;
  }

  .blog-card-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.2;
    transition: color 250ms ease;
  }

  .blog-card:hover .blog-card-title {
    color: rgba(255, 255, 255, 1);
  }

  .blog-card-excerpt {
    margin: 0;
    font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(0.72rem, 0.9vw, 0.82rem);
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.55;
    font-weight: 400;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.3rem;
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.3);
    transition: color 200ms ease, gap 200ms ease;
  }

  .blog-featured:hover .blog-card-cta,
  .blog-card:hover .blog-card-cta {
    color: rgba(255, 255, 255, 0.65);
    gap: 0.5rem;
  }

  /* ── Reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll("[data-reveal]");
    if (!els.length) return;
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            var delay = parseInt(e.target.getAttribute("data-reveal-delay") || "0", 10);
            setTimeout(function () {
              e.target.classList.add("revealed");
            }, delay * 120);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    els.forEach(function (el) { io.observe(el); });
  })();
</script>
