<script is:inline>
  (function () {
    const img = document.querySelector("[data-v2-bg-img]");
    const sun = document.querySelector("[data-v2-sun]");
    if (!img || !sun) return;

    const NIGHT = "/vessel-bg.gif";
    const DAY = "/vessel-bg-day.gif";
    const KEY = "v2-bg-mode"; // "day" | "night" = manual override; absent = auto (Brussels time)

    // Daytime in Brussels (07:00–18:59, CET/CEST — DST handled by Intl) → light.
    const autoMode = () => {
      let h;
      try {
        h = parseInt(new Intl.DateTimeFormat("en-GB", {
          hour: "numeric", hour12: false, timeZone: "Europe/Brussels",
        }).format(new Date()), 10);
      } catch (e) {
        h = new Date().getHours();
      }
      return h >= 7 && h < 19 ? "day" : "night";
    };

    const stored = (function () {
      try { return localStorage.getItem(KEY); } catch (e) { return null; }
    })();
    let manual = stored === "day" || stored === "night" ? stored : null;

    const apply = () => {
      const mode = manual || autoMode();
      img.setAttribute("src", mode === "day" ? DAY : NIGHT);
      sun.setAttribute("data-mode", mode);
    };

    apply();

    // Re-check every minute so the background flips on its own as Brussels time
    // crosses dawn/dusk — unless the visitor has manually overridden it.
    setInterval(function () { if (!manual) apply(); }, 60000);

    sun.addEventListener("click", () => {
      manual = (manual || autoMode()) === "day" ? "night" : "day";
      try { localStorage.setItem(KEY, manual); } catch (e) {}
      apply();
    });
  })();

  (function () {
    const cal = document.querySelector("[data-cal]");
    if (!cal) return;
    const months = Array.prototype.slice.call(cal.querySelectorAll("[data-cal-month]"));
    const label = cal.querySelector("[data-cal-label]");
    const prev = cal.querySelector("[data-cal-prev]");
    const next = cal.querySelector("[data-cal-next]");
    if (!months.length || !label || !prev || !next) return;

    let index = 0;
    const show = (i) => {
      index = Math.max(0, Math.min(months.length - 1, i));
      months.forEach((m, mi) => { m.hidden = mi !== index; });
      label.textContent = months[index].getAttribute("data-cal-monthlabel");
      prev.disabled = index === 0;
      next.disabled = index === months.length - 1;
    };

    prev.addEventListener("click", () => show(index - 1));
    next.addEventListener("click", () => show(index + 1));
    show(0);
  })();

</script>

<style is:global>
  /* ── Calendar (simple, static) ── */
  .v2-cal {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: clamp(1rem, 3vh, 2.5rem) auto;
    padding: clamp(1.4rem, 3vw, 2rem);
    background: rgba(12, 12, 14, 0.72);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
  }
  .v2-cal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .v2-cal-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .v2-cal-month {
    margin: 0;
    min-width: 9ch;
    font-family: "Instrument Serif", "Cormorant", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: rgba(255,255,255,0.92);
  }
  .v2-cal-arrow {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .v2-cal-arrow svg { width: 14px; height: 14px; }
  .v2-cal-arrow:hover:not(:disabled) {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.36);
    color: #fff;
  }
  .v2-cal-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .v2-cal-legend {
    margin: 0;
    display: flex;
    gap: 1rem;
    font-family: "Geist", sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.55);
  }
  .v2-cal-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .v2-cal-mark { width: 7px; height: 7px; border-radius: 50%; }
  .v2-cal-mark.is-openlab { background: #6ad7c5; }
  .v2-cal-mark.is-event { background: #f5b97e; }

  .v2-cal-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    font-family: "Geist", sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .v2-cal-week span { padding: 0 0 0.5rem 0.1rem; }

  .v2-cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border-top: 1px solid rgba(255,255,255,0.12);
    border-left: 1px solid rgba(255,255,255,0.12);
  }
  .v2-cal-grid[hidden] { display: none; }
  .v2-cal-cell {
    min-height: 64px;
    padding: 0.4rem 0.45rem;
    border-right: 1px solid rgba(255,255,255,0.12);
    border-bottom: 1px solid rgba(255,255,255,0.12);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .v2-cal-cell.is-past { opacity: 0.4; }
  .v2-cal-num {
    font-family: "Geist", sans-serif;
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.7);
  }
  .v2-cal-cell.is-today .v2-cal-num {
    align-self: flex-start;
    color: #0b0b0d;
    background: rgba(255,255,255,0.92);
    border-radius: 999px;
    min-width: 1.35rem;
    height: 1.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.3rem;
  }
  .v2-cal-entry {
    font-family: "Geist", sans-serif;
    font-size: 0.62rem;
    line-height: 1.25;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    padding-left: 0.55rem;
    border-left: 2px solid transparent;
    transition: color 150ms ease;
  }
  .v2-cal-entry:hover { color: #fff; }
  .v2-cal-entry.is-openlab { border-left-color: #6ad7c5; }
  .v2-cal-entry.is-event { border-left-color: #f5b97e; }

  @media (max-width: 640px) {
    .v2-cal-cell { min-height: 48px; padding: 0.3rem 0.3rem; }
    .v2-cal-num { font-size: 0.7rem; }
    .v2-cal-entry {
      font-size: 0;
      padding-left: 0;
      border-left: 0;
    }
    .v2-cal-entry::before {
      content: "";
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }
    .v2-cal-entry.is-openlab::before { background: #6ad7c5; }
    .v2-cal-entry.is-event::before { background: #f5b97e; }
  }


  /* ── Background ── */
  .v2-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #000;
    overflow: hidden;
    pointer-events: none;
  }
  .v2-bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Pixelated sun / moon toggle ── */
  .v2-sun {
    position: fixed;
    top: clamp(80px, 12vh, 130px);
    right: clamp(1.5rem, 5vw, 4.5rem);
    z-index: 3;
    width: clamp(46px, 5vw, 64px);
    height: clamp(46px, 5vw, 64px);
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: #f5d76e;
    filter: drop-shadow(0 0 14px rgba(255, 220, 130, 0.55))
            drop-shadow(0 0 28px rgba(255, 200, 100, 0.32));
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
                color 320ms ease,
                filter 320ms ease;
    animation: v2-sun-float 5.5s ease-in-out infinite;
  }
  .v2-sun:hover {
    transform: scale(1.08) rotate(8deg);
  }
  .v2-sun:active {
    transform: scale(0.96);
  }
  .v2-sun svg {
    width: 100%;
    height: 100%;
    display: block;
    image-rendering: pixelated;
  }
  .v2-sun svg rect {
    fill: currentColor;
  }
  .v2-sun[data-mode="night"] {
    color: #e6ecff;
    filter: drop-shadow(0 0 10px rgba(200, 220, 255, 0.4))
            drop-shadow(0 0 22px rgba(160, 190, 255, 0.22));
  }
  @keyframes v2-sun-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .v2-sun {
      animation: none;
    }
  }
  @media (max-width: 640px) {
    .v2-sun {
      top: clamp(70px, 10vh, 100px);
      right: 1.1rem;
    }
  }

  /* ── Hero ── */
  .v2-hero {
    position: relative;
    z-index: 2;
    min-height: calc(100dvh - 80px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(2rem, 5vh, 4rem) 1.2rem clamp(2rem, 4vh, 3rem);
    text-align: center;
    gap: clamp(1rem, 2vh, 1.8rem);
  }
  .v2-logo-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .v2-logo {
    display: block;
    width: min(640px, 82vw);
    height: auto;
    filter: drop-shadow(0 4px 18px rgba(0,0,0,0.85))
            drop-shadow(0 10px 60px rgba(0,0,0,0.65));
  }
  .v2-supported {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: clamp(-1.2rem, -2.4vh, -0.4rem);
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 200ms ease;
  }
  .v2-supported:hover { opacity: 1; }
  .v2-supported-label {
    font-family: "Geist", sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }
  .v2-supported img {
    height: clamp(24px, 3.4vw, 30px);
    width: auto;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.6));
  }
  @media (max-width: 480px) {
    .v2-supported { flex-direction: column; gap: 0.35rem; }
  }
  .v2-heading {
    margin: 0;
    max-width: 18ch;
    font-family: "Instrument Serif", "Cormorant", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 5.4vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: rgba(255,255,255,0.96);
    text-shadow:
      0 1px 2px rgba(0,0,0,0.9),
      0 4px 14px rgba(0,0,0,0.85),
      0 12px 48px rgba(0,0,0,0.7);
  }
  .v2-sub {
    margin: clamp(1.8rem, 4vh, 2.8rem) 0 0;
    max-width: 30ch;
    font-family: "Instrument Serif", "Cormorant", serif;
    font-style: italic;
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    line-height: 1.4;
    font-weight: 400;
    color: rgba(255,255,255,0.92);
    letter-spacing: 0.005em;
    text-shadow:
      0 1px 2px rgba(0,0,0,0.9),
      0 3px 12px rgba(0,0,0,0.8),
      0 10px 40px rgba(0,0,0,0.65);
  }
  /* ── Polaroid scatter board ── */
  .v2-board {
    list-style: none;
    margin: 0;
    padding: clamp(1.6rem, 4vh, 2.6rem) clamp(1rem, 4vw, 2rem) clamp(2rem, 5vh, 3.2rem);
    width: 100vw;
    margin-left: calc(50% - 50vw);
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: clamp(-0.4rem, -0.4vw, 0.4rem);
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .v2-board::-webkit-scrollbar { display: none; }
  .v2-polaroid {
    flex-shrink: 0;
    width: clamp(170px, 21vw, 230px);
    padding: 10px 10px 14px;
    background: #f5f1e8;
    border-radius: 2px;
    box-shadow:
      0 1px 0 rgba(0,0,0,0.05) inset,
      0 18px 36px -14px rgba(0,0,0,0.7),
      0 6px 14px -6px rgba(0,0,0,0.45);
    transform: rotate(var(--rot, 0deg)) translateY(var(--lift, 0));
    transition: transform 380ms cubic-bezier(0.2, 0.9, 0.3, 1.4),
                box-shadow 240ms ease,
                z-index 0s linear 240ms;
    position: relative;
    z-index: 1;
    scroll-snap-align: center;
  }
  .v2-polaroid:nth-child(odd) { margin-right: -1.2rem; }
  .v2-polaroid:nth-child(even) { margin-left: -0.8rem; }
  .v2-polaroid:hover,
  .v2-polaroid:focus-within {
    transform: rotate(0deg) translateY(-8px) scale(1.04);
    z-index: 5;
    box-shadow:
      0 1px 0 rgba(0,0,0,0.05) inset,
      0 28px 50px -14px rgba(0,0,0,0.78),
      0 10px 20px -8px rgba(0,0,0,0.55);
    transition: transform 320ms cubic-bezier(0.2, 0.9, 0.3, 1.4),
                box-shadow 240ms ease;
  }
  .v2-polaroid figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .v2-polaroid img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: #0a0a0c;
  }
  .v2-polaroid figcaption {
    font-family: "Caveat", "Bradley Hand", "Brush Script MT", cursive;
    font-weight: 600;
    font-size: 1.45rem;
    line-height: 1;
    text-align: center;
    text-transform: lowercase;
    color: #1a1206;
    padding: 2px 4px 0;
    letter-spacing: 0.005em;
  }
  @media (max-width: 720px) {
    .v2-board {
      justify-content: flex-start;
      gap: 0.4rem;
      padding-inline: 1.2rem;
    }
    .v2-polaroid {
      width: clamp(170px, 65vw, 220px);
    }
    .v2-polaroid:nth-child(odd),
    .v2-polaroid:nth-child(even) {
      margin: 0;
    }
  }

  .v2-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 0;
  }
  .v2-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.6rem;
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 220ms ease, color 220ms ease, transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }
  .v2-btn-primary {
    background: rgba(255,255,255,0.96);
    color: #0b0b0d;
    box-shadow: 0 8px 24px -8px rgba(0,0,0,0.4);
  }
  .v2-btn-primary:hover { background: #fff; transform: translateY(-1px); box-shadow: 0 10px 28px -8px rgba(0,0,0,0.5); }
  .v2-btn-secondary {
    background: rgba(12, 12, 14, 0.55);
    color: rgba(255,255,255,1);
    border: 1px solid rgba(255,255,255,0.6);
    backdrop-filter: blur(10px) saturate(1.15);
    -webkit-backdrop-filter: blur(10px) saturate(1.15);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 4px 18px rgba(0,0,0,0.35);
    text-shadow: 0 1px 2px rgba(0,0,0,0.7);
  }
  .v2-btn-secondary:hover {
    background: rgba(12, 12, 14, 0.72);
    border-color: rgba(255,255,255,0.9);
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.12) inset,
      0 8px 24px rgba(0,0,0,0.5);
  }
  .v2-btn svg { transition: transform 200ms ease; }
  .v2-btn:hover svg { transform: translateX(2px); }

  /* ── Scroll indicator ── */
  .v2-scroll {
    margin-top: clamp(1rem, 2vh, 2rem);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 0;
    color: rgba(255,255,255,0.6);
    font-family: "Geist", sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 200ms ease;
  }
  .v2-scroll:hover { color: #fff; }
  .v2-scroll-arrow {
    width: 14px;
    height: 14px;
    animation: v2-bob 2s ease-in-out infinite;
  }
  @keyframes v2-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  /* ── Below the fold ── */
  .v2-content {
    position: relative;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(6, 10, 22, 0.78) 12%,
      rgba(6, 10, 22, 0.9) 25%,
      rgba(6, 10, 22, 0.9) 75%,
      rgba(6, 10, 22, 0.78) 88%,
      transparent 100%
    );
  }
  .v2-section {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(3.5rem, 8vh, 6rem) clamp(1.2rem, 4vw, 2.4rem);
  }
  .v2-section + .v2-section { border-top: 1px solid rgba(255,255,255,0.08); }
  .v2-eyebrow {
    display: block;
    font-family: "Geist", sans-serif;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.42);
    margin-bottom: 0.9rem;
  }
  .v2-h2 {
    margin: 0 0 1.4rem;
    font-family: "Instrument Serif", "Cormorant", serif;
    font-style: italic;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 400;
    line-height: 1.1;
    color: rgba(255,255,255,0.98);
    letter-spacing: -0.01em;
    text-shadow:
      0 1px 2px rgba(0,0,0,0.9),
      0 4px 14px rgba(0,0,0,0.8),
      0 12px 44px rgba(0,0,0,0.6);
  }
  .v2-prose p {
    margin: 0 0 1rem;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.96rem, 1.1vw, 1.05rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.86);
    max-width: 62ch;
    text-shadow:
      0 1px 2px rgba(0,0,0,0.7),
      0 3px 10px rgba(0,0,0,0.55);
  }
  .v2-prose a {
    color: rgba(255,255,255,0.94);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255,255,255,0.25);
  }

  /* ── Keep in touch ── */
  .v2-keep-socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin: 0 0 2rem;
  }
  .v2-keep-socials a {
    display: inline-flex;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 200ms ease, transform 200ms ease;
  }
  .v2-keep-socials a:hover {
    color: #fff;
    transform: translateY(-2px);
  }
  .v2-keep-socials svg {
    width: 40px;
    height: 40px;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.55));
  }
  .v2-keep-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  /* ── Map ── */
  .v2-map {
    position: relative;
    margin: 1.4rem 0 1.4rem;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    overflow: hidden;
    background: rgba(8, 8, 10, 0.55);
    box-shadow: 0 24px 60px -22px rgba(0,0,0,0.65);
  }
  .v2-map-canvas {
    width: 100%;
    height: clamp(360px, 56vh, 540px);
    background: #0a0a0c;
  }
  /* Leaflet container baseline: kill default white background */
  .v2-map .leaflet-container {
    background: #0a0a0c;
    font-family: "Geist", sans-serif;
    outline: none;
  }
  .v2-map .leaflet-control-attribution {
    background: rgba(8, 8, 10, 0.65);
    color: rgba(255,255,255,0.45);
    font-size: 0.62rem;
    padding: 2px 6px;
  }
  .v2-map .leaflet-control-attribution a {
    color: rgba(255,255,255,0.7);
  }
  .v2-map .leaflet-bar {
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(8, 8, 10, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 6px 16px -6px rgba(0,0,0,0.6);
    border-radius: 8px;
    overflow: hidden;
  }
  .v2-map .leaflet-bar a {
    background: transparent;
    color: rgba(255,255,255,0.82);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    width: 28px;
    height: 28px;
    line-height: 28px;
  }
  .v2-map .leaflet-bar a:last-child { border-bottom: 0; }
  .v2-map .leaflet-bar a:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  /* ── Pin dots ── */
  .v2-map-dot { overflow: visible !important; }
  .v2-map-dot-inner {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--pin, #e8e6e0);
    box-shadow:
      0 0 0 2px rgba(8, 8, 10, 0.85),
      0 0 0 3px rgba(255, 255, 255, 0.14);
  }
  .v2-map-dot-vessel .v2-map-dot-inner {
    box-shadow:
      0 0 0 2px rgba(8, 8, 10, 0.9),
      0 0 0 3px rgba(245, 215, 110, 0.6),
      0 0 22px rgba(245, 215, 110, 0.55);
    animation: v2-pin-pulse 2.6s ease-in-out infinite;
  }

  /* Small tram stop pip */
  .v2-map-stop { overflow: visible !important; }
  .v2-map-stop-inner {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--pin, #cfd6e0);
    box-shadow:
      0 0 0 1.5px rgba(8, 8, 10, 0.9),
      0 0 0 2.5px rgba(255, 255, 255, 0.12);
    transition: transform 180ms ease;
  }
  .v2-map-stop:hover .v2-map-stop-inner {
    transform: scale(1.4);
  }
  @keyframes v2-pin-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.18); }
  }

  /* ── Tooltips ── */
  .v2-map-tip.leaflet-tooltip {
    display: flex;
    flex-direction: column;
    opacity: 1 !important;
    background: rgba(8, 8, 10, 0.92);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow: 0 10px 28px -8px rgba(0,0,0,0.85);
    color: #fff;
    font-family: "Geist", sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    padding: 5px 9px;
    border-radius: 6px;
    line-height: 1.2;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .v2-map-tip.leaflet-tooltip::before { border: 0; display: none; }
  .v2-map-tip-name {
    display: block;
    font-weight: 600;
    color: #fff;
  }
  .v2-map-tip-sub {
    display: block;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-top: 2px;
  }
