---
import Layout from '../layouts/Layout.astro';
import { ArrowUpRight } from 'lucide-react';

const directions = [
    { mode: "Train", detail: "Antwerpen-Centraal → Antwerpen-Luchtbal (NMBS, ~10 min, every 20 min)." },
    { mode: "Tram 6", detail: "From Diamant → Kinepolis terminus, ~30 min." },
    { mode: "Tram 1", detail: "From Opera, runs to Luchtbal." },
    { mode: "Bike", detail: "~20 min from Antwerp centre via Italiëlei. Covered racks at the door." },
    { mode: "Car", detail: "~10 min from centre. Free parking on-site at Loodglansstraat 5." },
];

const equipment = [
    { qty: "×4", name: "SO-101 arm", body: "Hugging Face LeRobot 6-axis arms. Leader / follower teleoperation, imitation learning workflows.", image: "/vessel/equipment/so101.png" },
    { qty: "×1", name: "LeKiwi", body: "Mobile base from the LeRobot ecosystem. SO-101 mounted on wheels for navigation experiments.", image: "/vessel/equipment/lekiwi.jpg" },
    { qty: "×1", name: "Bambu Lab A1", body: "Multi-material 3D printer. Keeps the lab self-sufficient for parts, jigs, and prototypes.", image: "/vessel/equipment/bambu-a1.png" },
    { qty: "×1", name: "Meta Quest 3", body: "Mixed-reality headset used for VR teleoperation and 3D scene visualisation.", image: "/vessel/equipment/quest-3.jpg" },
    { qty: "×1", name: "Sesame", body: "Open-source ESP32 mini quadruped. A pocket-sized robot for tinkering and demos.", image: "/vessel/equipment/sesame.png" },
    { qty: "×1", name: "reCamera Gimbal", body: "Seeed Studio open-source AI camera on a 2-axis brushless gimbal for YOLO at the edge.", image: "/vessel/equipment/recamera-gimbal.jpg" },
    { qty: "Soon", name: "Amazing Hand", body: "Pollen Robotics × Hugging Face open-source dexterous hand. 8 DoF across four fingers.", image: "/vessel/equipment/amazing-hand.jpg" },
];
---

<Layout title="The Vessel | North Star">
    <main class="vessel-page">

        <!-- Hero -->
        <section class="vessel-section" data-reveal>
            <div class="vessel-bg" aria-hidden="true">
                <img src="/thevessel.png" alt="" loading="eager" fetchpriority="high" />
            </div>
            <div class="vessel-gradient-b" aria-hidden="true"></div>
            <div class="vessel-gradient-r" aria-hidden="true"></div>
            <div class="vessel-vignette" aria-hidden="true"></div>
            <div class="vessel-content">
                <span class="vessel-eyebrow">First open Robotics and AI lab in Belgium</span>
                <h1 class="vessel-title">The Vessel</h1>
                <p class="vessel-desc">An atelier for intelligent machines.</p>
                <div class="vessel-supporter">
                    <span class="vessel-supporter-label">Supported by</span>
                    <img src="/partnerships/workedwith/17.png" alt="Port of Antwerp-Bruges" class="vessel-supporter-logo" />
                </div>
            </div>
        </section>

        <!-- Visual -->
        <section class="vp-shot" data-reveal>
            <img src="/blogs/the-vessel/SCR-20260310-ozkx.jpeg" alt="The Vessel at Port of Antwerp-Bruges" loading="lazy" />
        </section>

        <!-- The idea -->
        <section class="vp-section" data-reveal>
            <h2 class="vp-section-title">A forever hackathon.</h2>

            <div class="vp-definition">
                <p class="vp-def-word">vessel <span class="vp-def-phon">/&#x02C8;ves.&#x0259;l/</span></p>
                <ol class="vp-def-list">
                    <li><strong>A container.</strong> Something that holds things.</li>
                    <li><strong>A ship.</strong> A way to get somewhere.</li>
                    <li><strong>A carrier.</strong> Something that moves more than itself.</li>
                </ol>
            </div>

            <div class="vp-prose">
                <p>The Vessel is the first open AI and robotics lab in Belgium, hosted in the Antwerp port area. It runs continuously: projects rotate, people come and go, the knowledge compounds.</p>
                <p>In our first year we built the largest AI and robotics community in Belgium &mdash; 800+ builders, 18 events, 20+ hires across the ecosystem. The Vessel is the next step. Instead of one-off events, builders get sustained access to hardware, industrial context, and real challenges.</p>
            </div>
        </section>

        <!-- Directions -->
        <section class="vp-section" data-reveal>
            <h2 class="vp-section-title">Loodglansstraat&nbsp;5,<br/>2030 Antwerpen.</h2>

            <p class="vp-section-note">To enter, please join our <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer">Discord</a> and ping us there.</p>

            <div class="vp-map-frame">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2498.5!2d4.3847!3d51.2350!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c3f700b5e9c6f1%3A0x0!2sLoodglansstraat%205%2C%202030%20Antwerpen!5e0!3m2!1sen!2sbe!4v1"
                    width="100%"
                    height="320"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="The Vessel, Loodglansstraat 5, Antwerpen"></iframe>
            </div>

            <ul class="vp-directions">
                {directions.map((d) => (
                    <li class="vp-direction-row">
                        <span class="vp-direction-mode">{d.mode}</span>
                        <span class="vp-direction-detail">{d.detail}</span>
                    </li>
                ))}
            </ul>
        </section>

        <!-- Equipment -->
        <section class="vp-section" data-reveal>
            <h2 class="vp-section-title">What's in the lab.</h2>

            <div class="vp-equipment-grid">
                {equipment.map((e) => (
                    <article class="vp-eq-card">
                        <div class="vp-eq-thumb" style={`--thumb-bg: url('${e.image}')`}>
                            <img src={e.image} alt={e.name} loading="lazy" />
                        </div>
                        <div class="vp-eq-meta">
                            <span class="vp-eq-qty">{e.qty}</span>
                            <h3 class="vp-eq-name">{e.name}</h3>
                        </div>
                        <p class="vp-eq-body">{e.body}</p>
                    </article>
                ))}
            </div>

            <p class="vp-eq-bench">Plus the bench: soldering station, hand tools, calipers, screwdrivers, a stocked parts drawer.</p>
        </section>

        <!-- Vision -->
        <section class="vp-section vp-vision" data-reveal>
            <p class="vp-vision-quote">A vessel has a destination.<br/>This is the start of our journey.</p>
            <div class="vp-prose vp-vision-prose">
                <p>We want Belgium to be a place where ambitious people building in AI and robotics have somewhere real to land. Hardware in front of them, context around them, and other builders within arm&rsquo;s reach.</p>
                <p>The Vessel is how we begin. A space where the people willing to show up on a sunny Saturday in exchange for pizza can keep showing up. Where curiosity becomes craft, and craft becomes the next company, the next research direction, the next hire.</p>
                <p>Five years from now, we want to look back at this room and recognise the people who shaped what came next.</p>
            </div>
        </section>

        <!-- CTA -->
        <section class="vp-cta" data-reveal>
            <h2 class="vp-cta-title">Come build with us.</h2>
            <div class="vp-cta-actions">
                <a href="https://etoile.events/events/3ec37af2-d267-4031-bf8f-9cb69d89dbee" target="_blank" rel="noopener noreferrer" class="vp-cta-primary">
                    Join Open Lab Thursday <ArrowUpRight className="w-3.5 h-3.5" />
                </a>
                <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer" class="vp-cta-secondary">Join the Discord</a>
                <a href="/work-with-us" class="vp-cta-secondary">Partner with the lab</a>
            </div>
            <p class="vp-cta-mail">Or write directly: <a href="mailto:filip@ns2agi.com">filip@ns2agi.com</a></p>
        </section>

    </main>
</Layout>

<style is:global>
    .vessel-page {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* ── Reveal ── */
    [data-reveal] {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }

    /* ── Hero (mirrors homepage Vessel tile) ── */
    .vessel-section {
        position: relative;
        overflow: hidden;
        min-height: clamp(280px, 42vh, 420px);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: clamp(2rem, 5vh, 4rem) -1.5rem clamp(2rem, 4vh, 3rem);
        border-radius: 0;
    }
    @media (min-width: 768px) {
        .vessel-section {
            margin: clamp(2rem, 4vh, 3rem) 0 clamp(2.5rem, 5vh, 4rem);
            border-radius: 1rem;
        }
    }
    .vessel-bg {
        position: absolute;
        inset: 0;
    }
    .vessel-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.18;
    }
    .vessel-gradient-b {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
        pointer-events: none;
    }
    .vessel-gradient-r {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
        pointer-events: none;
    }
    .vessel-vignette {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 35% 35% at 50% 40%, transparent 0%, var(--offblack) 100%);
        pointer-events: none;
    }
    .vessel-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: clamp(3rem, 6vh, 5rem) 1.5rem;
        gap: 0.6rem;
    }
    .vessel-eyebrow {
        display: block;
        font-family: "Geist", sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.32);
        margin-bottom: 0.6rem;
    }
    .vessel-title {
        margin: 0;
        font-family: "Cormorant", serif;
        font-size: clamp(2.2rem, 5vw, 3.4rem);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255,255,255,0.9);
        line-height: 1;
    }
    .vessel-desc {
        margin: 0;
        max-width: 38ch;
        font-family: "Geist", sans-serif;
        font-size: clamp(0.88rem, 1.25vw, 1rem);
        color: rgba(255,255,255,0.5);
        line-height: 1.55;
    }
    .vessel-supporter {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.8rem;
        padding-top: 0.6rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    .vessel-supporter-label {
        font-family: "Geist", sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.25);
    }
    .vessel-supporter-logo {
        height: clamp(1.6rem, 3vw, 2.2rem);
        width: auto;
        object-fit: contain;
        opacity: 0.85;
    }

    /* ── Hero shot ── */
    .vp-shot {
        margin: 0 0 clamp(3rem, 6vh, 5rem);
    }
    .vp-shot img {
        display: block;
        width: 100%;
        border-radius: 0.75rem;
        border: 1px solid rgba(255,255,255,0.06);
    }

    /* ── Section structure ── */
    .vp-section {
        padding: clamp(3rem, 6vh, 5rem) 0;
        border-top: 1px solid rgba(255,255,255,0.06);
    }
    .vp-section-eyebrow {
        display: block;
        font-family: "Geist", sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.28);
        margin-bottom: 0.8rem;
    }
    .vp-section-title {
        margin: 0 0 clamp(1.8rem, 3.5vh, 2.6rem);
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: clamp(1.8rem, 3.6vw, 2.6rem);
        font-weight: 400;
        color: rgba(255,255,255,0.88);
        line-height: 1.1;
        letter-spacing: -0.01em;
    }
    .vp-section-note {
        margin: 0 0 1.5rem;
        font-family: "Geist", sans-serif;
        font-size: 0.86rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.42);
    }
    .vp-section-note a {
        color: rgba(255,255,255,0.78);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(255,255,255,0.2);
        transition: color 200ms ease, text-decoration-color 200ms ease;
    }
    .vp-section-note a:hover {
        color: rgba(255,255,255,0.95);
        text-decoration-color: rgba(255,255,255,0.5);
    }

    /* ── Prose ── */
    .vp-prose {
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
    }
    .vp-prose p {
        margin: 0;
        font-family: "Geist", -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: clamp(0.95rem, 1.1vw, 1.05rem);
        line-height: 1.8;
        color: rgba(255,255,255,0.55);
        font-weight: 400;
        max-width: 62ch;
    }
    .vp-prose strong {
        color: rgba(255,255,255,0.88);
        font-weight: 700;
    }

    /* ── Definition ── */
    .vp-definition {
        margin: 0 0 2rem;
        padding: 1.4rem 0 1.4rem 1.5rem;
        border-left: 2px solid rgba(255,255,255,0.12);
    }
    .vp-def-word {
        margin: 0 0 0.8rem;
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: clamp(1.3rem, 2vw, 1.6rem);
        color: rgba(255,255,255,0.85);
        line-height: 1;
    }
    .vp-def-phon {
        font-family: "Geist", sans-serif;
        font-style: normal;
        font-size: 0.82rem;
        color: rgba(255,255,255,0.3);
        margin-left: 0.4rem;
    }
    .vp-def-list {
        margin: 0;
        padding-left: 1.2rem;
        list-style: decimal;
    }
    .vp-def-list li {
        font-family: "Geist", sans-serif;
        font-size: clamp(0.88rem, 1.05vw, 0.98rem);
        line-height: 1.7;
        color: rgba(255,255,255,0.5);
        margin-bottom: 0.25rem;
    }
    .vp-def-list li strong {
        color: rgba(255,255,255,0.78);
        font-weight: 600;
    }

    /* ── Map ── */
    .vp-map-frame {
        margin: 0 0 1.8rem;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 0.75rem;
        overflow: hidden;
        background: rgba(255,255,255,0.02);
    }
    .vp-map-frame iframe {
        display: block;
        filter: grayscale(35%) brightness(0.85);
        transition: filter 400ms ease;
    }
    .vp-map-frame:hover iframe {
        filter: grayscale(0%) brightness(1);
    }

    /* ── Directions list ── */
    .vp-directions {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
    }
    .vp-direction-row {
        display: grid;
        grid-template-columns: 5.5rem 1fr;
        gap: 1.2rem;
        padding: 0.85rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        align-items: baseline;
    }
    .vp-direction-row:last-child {
        border-bottom: none;
    }
    .vp-direction-mode {
        font-family: "Geist", sans-serif;
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.38);
    }
    .vp-direction-detail {
        font-family: "Geist", sans-serif;
        font-size: 0.92rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.62);
    }

    /* ── Projects rows ── */
    .vp-project-list {
        display: flex;
        flex-direction: column;
    }
    .vp-project-row {
        display: grid;
        grid-template-columns: 12rem 1fr 1rem;
        gap: 1.5rem;
        align-items: baseline;
        padding: 1.1rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        text-decoration: none;
        color: inherit;
        transition: padding 250ms ease;
    }
    .vp-project-row:hover {
        padding-left: 0.4rem;
    }
    .vp-project-row:last-child {
        border-bottom: none;
    }
    @media (max-width: 640px) {
        .vp-project-row {
            grid-template-columns: 1fr 1rem;
            gap: 0.4rem;
            row-gap: 0.4rem;
        }
        .vp-project-row .vp-project-arrow {
            grid-row: 1;
            grid-column: 2;
        }
        .vp-project-name {
            grid-row: 1;
            grid-column: 1;
        }
        .vp-project-body {
            grid-row: 2;
            grid-column: 1 / -1;
        }
    }
    .vp-project-name {
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: clamp(1.1rem, 1.5vw, 1.3rem);
        color: rgba(255,255,255,0.86);
        line-height: 1.15;
    }
    .vp-project-body {
        font-family: "Geist", sans-serif;
        font-size: 0.9rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.5);
    }
    .vp-project-arrow {
        color: rgba(255,255,255,0.25);
        transition: color 250ms ease, transform 250ms ease;
    }
    .vp-project-row:hover .vp-project-arrow {
        color: rgba(255,255,255,0.7);
        transform: translateX(3px);
    }


    /* ── Equipment ── */
    .vp-equipment-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.4rem 1.2rem;
        margin: 0 0 2rem;
    }
    @media (max-width: 640px) {
        .vp-equipment-grid {
            grid-template-columns: 1fr;
        }
    }
    .vp-eq-card {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }
    .vp-eq-thumb {
        position: relative;
        aspect-ratio: 4 / 3;
        border-radius: 0.6rem;
        overflow: hidden;
        background: var(--offblack);
        border: 1px solid rgba(255,255,255,0.05);
        isolation: isolate;
    }
    .vp-eq-thumb::before {
        content: "";
        position: absolute;
        inset: -8%;
        background-image: var(--thumb-bg);
        background-size: cover;
        background-position: center;
        filter: blur(28px) saturate(1.1) brightness(0.55);
        transform: scale(1.15);
        z-index: 0;
    }
    .vp-eq-thumb img {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
    .vp-eq-meta {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
    }
    .vp-eq-qty {
        font-family: "Geist Mono", "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        color: rgba(255,255,255,0.38);
        font-variant-numeric: tabular-nums;
        flex-shrink: 0;
    }
    .vp-eq-name {
        margin: 0;
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: 1.2rem;
        font-weight: 400;
        line-height: 1.15;
        color: rgba(255,255,255,0.92);
    }
    .vp-eq-body {
        margin: 0;
        font-family: "Geist", sans-serif;
        font-size: 0.84rem;
        line-height: 1.55;
        color: rgba(255,255,255,0.5);
    }
    .vp-eq-bench {
        margin: 0;
        padding-top: 1.4rem;
        border-top: 1px solid rgba(255,255,255,0.04);
        font-family: "Geist", sans-serif;
        font-size: 0.84rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.42);
        font-style: italic;
    }

    /* ── Vision ── */
    .vp-vision-quote {
        margin: 1rem 0 2.4rem;
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: clamp(1.6rem, 3.2vw, 2.4rem);
        line-height: 1.2;
        color: rgba(255,255,255,0.86);
        text-align: left;
    }
    .vp-vision-prose p {
        max-width: 62ch;
    }

    /* ── CTA ── */
    .vp-cta {
        padding: clamp(4rem, 8vh, 6rem) 0 clamp(5rem, 10vh, 8rem);
        border-top: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }
    .vp-cta-title {
        margin: 0 0 1.8rem;
        font-family: "Instrument Serif", serif;
        font-style: italic;
        font-size: clamp(1.8rem, 3.6vw, 2.6rem);
        font-weight: 400;
        color: rgba(255,255,255,0.9);
        line-height: 1.1;
    }
    .vp-cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        justify-content: center;
        margin-bottom: 1.4rem;
    }
    .vp-cta-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.2rem;
        border-radius: 9999px;
        background: rgba(255,255,255,0.92);
        color: #0f0e0c;
        font-family: "Geist", sans-serif;
        font-size: 0.86rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 200ms ease, transform 200ms ease;
    }
    .vp-cta-primary:hover {
        background: rgba(255,255,255,1);
        transform: translateY(-1px);
    }
    .vp-cta-primary:active {
        transform: translateY(0);
    }
    .vp-cta-secondary {
        display: inline-flex;
        align-items: center;
        padding: 0.7rem 1.2rem;
        border-radius: 9999px;
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.78);
        font-family: "Geist", sans-serif;
        font-size: 0.86rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 200ms ease, color 200ms ease, background 200ms ease;
    }
    .vp-cta-secondary:hover {
        border-color: rgba(255,255,255,0.28);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.95);
    }
    .vp-cta-mail {
        margin: 0;
        font-family: "Geist", sans-serif;
        font-size: 0.84rem;
        color: rgba(255,255,255,0.4);
    }
    .vp-cta-mail a {
        color: rgba(255,255,255,0.78);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(255,255,255,0.2);
        transition: color 200ms ease, text-decoration-color 200ms ease;
    }
    .vp-cta-mail a:hover {
        color: rgba(255,255,255,0.98);
        text-decoration-color: rgba(255,255,255,0.5);
    }
</style>

<script is:inline>
    (function () {
        const els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        const io = new IntersectionObserver(
            (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("revealed"); io.unobserve(e.target); } }),
            { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
    })();
</script>
