---
import Layout from "../layouts/Layout.astro";
import VesselMap from "../components/VesselMap";
import { allEvents } from "../lib/events";
import { getEventLink } from "../lib/event-routes";

// ── Calendar: Vessel-only events + recurring Thu/Sat Open Labs ─
type CalEntry = {
  date: string;
  title: string;
  href: string;
  type: "openlab" | "event";
};

const pad = (n: number) => String(n).padStart(2, "0");
const isoOf = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
const today = new Date();
const todayISO = isoOf(today);

// Any event held at The Vessel — matched on id, title, or description text.
const isVesselEvent = (e: typeof allEvents[number]) => {
  const blob = `${e.id} ${e.title} ${e.description}`.toLowerCase();
  return blob.includes("vessel") || blob.includes("openlab");
};

const vesselEventHref = (e: typeof allEvents[number]) => e.link ?? getEventLink(e.id, "/vessel");

const monthAnchor = {
  label: today.toLocaleDateString("en-US", { month: "long", year: "numeric" }),
  year: today.getFullYear(),
  month: today.getMonth(),
};

const buildMonth = (year: number, month: number) => {
  const last = new Date(year, month + 1, 0);
  const daysInMonth = last.getDate();
  const startWeekday = (new Date(year, month, 1).getDay() + 6) % 7; // Mon-first

  const byDate = new Map<string, CalEntry[]>();
  const push = (entry: CalEntry) => {
    const arr = byDate.get(entry.date) ?? [];
    arr.push(entry);
    byDate.set(entry.date, arr);
  };

  for (const e of allEvents) {
    if (!e.date.startsWith(`${year}-${pad(month + 1)}`)) continue;
    if (!isVesselEvent(e)) continue;
    push({ date: e.date, title: e.title, href: vesselEventHref(e), type: "event" });
  }

  for (let day = 1; day <= daysInMonth; day++) {
    const d = new Date(year, month, day);
    const dow = d.getDay();
    if (dow === 4 || dow === 6) {
      push({ date: isoOf(d), title: "Open Lab", href: "https://discord.gg/m5Hknymurb", type: "openlab" });
    }
  }

  const cells: { day: number | null; entries: CalEntry[]; isToday: boolean; isPast: boolean }[] = [];
  for (let i = 0; i < startWeekday; i++) cells.push({ day: null, entries: [], isToday: false, isPast: false });
  for (let day = 1; day <= daysInMonth; day++) {
    const date = `${year}-${pad(month + 1)}-${pad(day)}`;
    cells.push({
      day,
      entries: byDate.get(date) ?? [],
      isToday: date === todayISO,
      isPast: date < todayISO,
    });
  }
  while (cells.length < 42) cells.push({ day: null, entries: [], isToday: false, isPast: false });
  return cells;
};

const isExternal = (href: string) => href.startsWith("http");

const MONTHS_AHEAD = 12;
const months = Array.from({ length: MONTHS_AHEAD + 1 }, (_, i) => {
  const d = new Date(monthAnchor.year, monthAnchor.month + i, 1);
  return {
    label: d.toLocaleDateString("en-US", { month: "long", year: "numeric" }),
    cells: buildMonth(d.getFullYear(), d.getMonth()),
  };
});
const weekdayLabels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

const equipment = [
  { qty: "×4", name: "SO-101 arm", body: "Hugging Face LeRobot 6-axis arms. Leader / follower teleoperation, imitation learning workflows.", image: "/vessel/equipment/so101.png", href: "https://huggingface.co/docs/lerobot/so101" },
  { qty: "×1", name: "LeKiwi", body: "Mobile base from the LeRobot ecosystem. SO-101 mounted on wheels for navigation experiments.", image: "/vessel/equipment/lekiwi.jpg", href: "https://huggingface.co/docs/lerobot/lekiwi" },
  { qty: "×1", name: "Bambu Lab A1", body: "Multi-material 3D printer. Keeps the lab self-sufficient for parts, jigs, and prototypes.", image: "/vessel/equipment/bambu-a1.png", href: "https://eu.store.bambulab.com/products/a1" },
  { qty: "×1", name: "Meta Quest 3", body: "Mixed-reality headset used for VR teleoperation and 3D scene visualisation.", image: "/vessel/equipment/quest-3.jpg", href: "https://www.meta.com/quest/quest-3/" },
  { qty: "×1", name: "Sesame", body: "Open-source ESP32 mini quadruped. A pocket-sized robot for tinkering and demos.", image: "/vessel/equipment/sesame.png", href: "https://github.com/dorianborian/sesame-robot" },
  { qty: "×1", name: "reCamera Gimbal", body: "Seeed Studio open-source AI camera on a 2-axis brushless gimbal for YOLO at the edge.", image: "/vessel/equipment/recamera-gimbal.jpg", href: "https://www.seeedstudio.com/reCamera-Gimbal-2002w-8GB-p-6402.html" },
];

// Toggle to re-show the "What's in the lab" equipment gallery.
const showLab = false;

const strip = [
  { src: "/vessel/mosaic/day-0.jpeg", caption: "Day 0!" },
  { src: "/vessel/mosaic/1.jpeg", caption: "if person > 0.80" },
  { src: "/blogs/the-vessel/2026-03-10 16.58.10.jpg", caption: "Open Lab Thursday" },
  { src: "/blogs/the-vessel/2026-03-10 16.56.25.jpg", caption: "research paper club!" },
  { src: "/vessel/mosaic/3.jpeg", caption: "AI Workshop" },
];
---

<Layout title="The Vessel | North Star">
  <div class="v2-bg" data-v2-bg aria-hidden="true">
    <img src="/vessel-bg.gif" alt="" data-v2-bg-img />
  </div>

  <button
    type="button"
    class="v2-sun"
    data-v2-sun
    aria-label="Toggle day / night"
    title="Toggle day / night"
  >
    <svg viewBox="0 0 32 32" shape-rendering="crispEdges" aria-hidden="true">
      <g data-v2-sun-glyph>
        <rect x="14" y="3" width="4" height="3" />
        <rect x="14" y="26" width="4" height="3" />
        <rect x="3" y="14" width="3" height="4" />
        <rect x="26" y="14" width="3" height="4" />
        <rect x="6" y="6" width="3" height="3" />
        <rect x="23" y="6" width="3" height="3" />
        <rect x="6" y="23" width="3" height="3" />
        <rect x="23" y="23" width="3" height="3" />
        <rect x="11" y="9" width="10" height="2" />
        <rect x="9" y="11" width="14" height="2" />
        <rect x="9" y="13" width="14" height="6" />
        <rect x="9" y="19" width="14" height="2" />
        <rect x="11" y="21" width="10" height="2" />
      </g>
    </svg>
  </button>

  <header class="v2-hero">
    <div class="v2-logo-group">
      <img src="/vessel/vessel-logo.png" alt="The Vessel" class="v2-logo" />
      <a
        class="v2-supported"
        href="https://www.portofantwerpbruges.com/en"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="v2-supported-label">Supported by</span>
        <img src="/partnerships/workedwith/17.png" alt="Port of Antwerp-Bruges" />
      </a>
    </div>

    <h1 class="v2-heading">Belgium's First Open<br />Robotics &amp; AI Lab</h1>

    <ul class="v2-board" aria-label="Photos from The Vessel">
      {strip.map((s, i) => {
        const rotations = [-3.5, 2.6, -1.4, 4.1, -2.8, 1.7];
        const lifts = [0, -10, 6, -14, 4, -4];
        return (
          <li class="v2-polaroid" style={`--rot:${rotations[i % rotations.length]}deg;--lift:${lifts[i % lifts.length]}px`}>
            <figure>
              <img src={s.src} alt={s.caption} loading="lazy" />
              <figcaption>{s.caption}</figcaption>
            </figure>
          </li>
        );
      })}
    </ul>

    <div class="v2-actions">
      <a href="#visit" class="v2-btn v2-btn-primary">
        Visit the Open Lab
        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a href="/events" class="v2-btn v2-btn-secondary">View Events</a>
    </div>

    <button class="v2-scroll" type="button" onclick="document.getElementById('about').scrollIntoView({behavior:'smooth'})">
      <span>Scroll to discover</span>
      <svg class="v2-scroll-arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 2v11M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </header>

  <section class="v2-cal" aria-label="Vessel calendar" data-cal data-cal-count={months.length}>
    <div class="v2-cal-head">
      <div class="v2-cal-nav">
        <button type="button" class="v2-cal-arrow" data-cal-prev aria-label="Previous month" disabled>
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <h2 class="v2-cal-month" data-cal-label aria-live="polite">{months[0].label}</h2>
        <button type="button" class="v2-cal-arrow" data-cal-next aria-label="Next month">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
      <p class="v2-cal-legend">
        <span><i class="v2-cal-mark is-openlab"></i>Open Lab</span>
        <span><i class="v2-cal-mark is-event"></i>Event</span>
      </p>
    </div>

    <div class="v2-cal-week" aria-hidden="true">
      {weekdayLabels.map((w) => <span>{w}</span>)}
    </div>

    {months.map((m, mi) => (
      <div class="v2-cal-grid" data-cal-month={mi} data-cal-monthlabel={m.label} hidden={mi !== 0}>
        {m.cells.map((c) => (
          <div class:list={["v2-cal-cell", c.day === null && "is-empty", c.isToday && "is-today", c.isPast && "is-past"]}>
            {c.day !== null && (
              <>
                <span class="v2-cal-num">{c.day}</span>
                {c.entries.map((entry) => (
                  <a
                    href={entry.href}
                    class:list={["v2-cal-entry", `is-${entry.type}`]}
                    target={isExternal(entry.href) ? "_blank" : undefined}
                    rel={isExternal(entry.href) ? "noopener noreferrer" : undefined}
                  >
                    {entry.title}
                  </a>
                ))}
              </>
            )}
          </div>
        ))}
      </div>
    ))}
  </section>

  <div class="v2-content">
    <section id="about" class="v2-section">
      <h2 class="v2-h2">A forever hackathon.</h2>
      <div class="v2-prose">
        <p>The Vessel is the first open AI and robotics lab in Belgium, hosted in the Antwerp port area. It runs continuously: projects rotate, people come and go, the knowledge compounds.</p>
      </div>
    </section>

    <section id="visit" class="v2-section">
      <h2 class="v2-h2">Loodglansstraat&nbsp;5,<br />2030&nbsp;Antwerpen.</h2>
      <div class="v2-prose">
        <p>To enter, please join our <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer">Discord</a> and ping us there. Open Lab runs Thursdays and Saturdays &mdash; come build with us.</p>
      </div>

      <figure class="v2-map">
        <VesselMap client:only="react" />
      </figure>

      <div class="v2-meta">
        <div class="v2-meta-row"><span class="v2-meta-key">Train</span><span class="v2-meta-val">Antwerpen-Centraal &rarr; Antwerpen-Luchtbal (NMBS, ~10 min, every 20 min).</span></div>
        <div class="v2-meta-row"><span class="v2-meta-key">Tram 6</span><span class="v2-meta-val">From Diamant &rarr; Kinepolis terminus, ~30 min.</span></div>
        <div class="v2-meta-row"><span class="v2-meta-key">Tram 1</span><span class="v2-meta-val">From Opera, runs to Luchtbal.</span></div>
        <div class="v2-meta-row"><span class="v2-meta-key">Bike</span><span class="v2-meta-val">~20 min from Antwerp centre via Itali&euml;lei. Covered racks at the door.</span></div>
        <div class="v2-meta-row"><span class="v2-meta-key">Car</span><span class="v2-meta-val">~10 min from centre. Free parking on-site at Loodglansstraat 5.</span></div>
      </div>
    </section>

    {showLab && (
    <section class="v2-section">
      <h2 class="v2-h2">What's in the lab.</h2>

      <div class="v2-gallery">
        {equipment.map((e) => (
          <a class="v2-tile" href={e.href} target="_blank" rel="noopener noreferrer" title={e.body} aria-label={e.name}>
            <div class="v2-tile-img" style={`--thumb-bg: url('${e.image}')`}>
              <img src={e.image} alt={e.name} loading="lazy" />
              <span class="v2-tile-qty">{e.qty}</span>
            </div>
            <span class="v2-tile-name">{e.name}</span>
          </a>
        ))}
      </div>

    </section>
    )}

    <section class="v2-section">
      <h2 class="v2-h2">A vessel has a destination.<br />This is the start of our journey.</h2>
      <div class="v2-prose">
        <p>We want Belgium to be a place where ambitious people building in AI and robotics have somewhere real to land. Hardware in front of them, context around them, and other builders within arm&rsquo;s reach.</p>
        <p>Five years from now, we want to look back at this room and recognise the people who shaped what came next.</p>
      </div>
    </section>

    <section class="v2-section v2-keep">
      <h2 class="v2-h2">Keep in touch.</h2>

      <nav class="v2-keep-socials" aria-label="North Star socials">
        <a href="https://www.linkedin.com/company/north-star-agi" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
