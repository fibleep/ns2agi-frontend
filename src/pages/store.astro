---
import Layout from "../layouts/Layout.astro";
import { ArrowUpRight } from "lucide-react";
import { getProducts, getProductUrl, getImageUrl, getStoreUrl, formatPrice } from "../lib/bigcartel";

const result = await getProducts();
const products = result.ok
  ? result.data.filter((p) => p.status?.toLowerCase() === "active")
  : [];
const fetchFailed = !result.ok;
const storeUrl = getStoreUrl();

const sortedProducts = [...products].sort(
  (a, b) => (a.position ?? 0) - (b.position ?? 0),
);
---

<Layout title="Merch | North Star">
  <main class="merch-page">
    <header class="merch-head">
      <h1 class="merch-title">Wear the Star.</h1>
    </header>

    {sortedProducts.length > 0 ? (
      <section class="merch-grid">
        {sortedProducts.map((product) => {
          const image = getImageUrl(product.images?.[0]);
          const href = getProductUrl(product.permalink);
          return (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="merch-card"
            >
              <div class="merch-thumb">
                {image ? (
                  <img src={image} alt={product.name} loading="lazy" />
                ) : (
                  <div class="merch-thumb-placeholder" aria-hidden="true"></div>
                )}
                {product.on_sale && <span class="merch-sale">On sale</span>}
              </div>
              <div class="merch-card-body">
                <h3 class="merch-card-name">{product.name}</h3>
                <p class="merch-card-price">{formatPrice(product.price)}</p>
              </div>
            </a>
          );
        })}
      </section>
    ) : (
      <section class="merch-empty">
        <p class="merch-empty-title">First drop landing soon.</p>
        <p class="merch-empty-body">
          We&rsquo;re putting the first pieces together. Check back, or
          peek at the storefront directly.
        </p>
        <a
          href={storeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="merch-cta"
        >
          Visit the store <ArrowUpRight className="merch-cta-arrow" />
        </a>
        {fetchFailed && (
          <p class="merch-empty-note" role="status">
            (Catalog couldn&rsquo;t load at build time. Refresh in a few hours.)
          </p>
        )}
      </section>
    )}

    <footer class="merch-foot">
      <p>For any questions, send a mail to <a href="mailto:filip@ns2agi.com">filip@ns2agi.com</a>.</p>
    </footer>
  </main>
</Layout>

<style>
  .merch-page {
    min-height: 100dvh;
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(5rem, 12vh, 9rem) clamp(1rem, 4vw, 2.5rem) clamp(4rem, 8vh, 7rem);
    color: rgba(255,255,255,0.92);
  }

  .merch-head {
    text-align: center;
    margin: 0 auto clamp(2.5rem, 6vh, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .merch-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.015em;
    color: rgba(255,255,255,0.96);
  }
  .merch-lede {
    margin: 0;
    max-width: 40ch;
    font-family: "Geist", sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.55);
  }

  .merch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 280px));
    gap: clamp(1rem, 2vw, 1.6rem);
    justify-content: center;
  }
  .merch-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    text-decoration: none;
    color: inherit;
  }
  .merch-thumb {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 0.85rem;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.05);
  }
  .merch-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .merch-thumb-placeholder {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 50% 40%, rgba(255,255,255,0.06), transparent 60%),
      var(--offblack);
  }
  .merch-sale {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.55rem;
    border-radius: 9999px;
    background: rgba(15,14,12,0.75);
    border: 1px solid rgba(255,255,255,0.18);
    font-family: "Geist", sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .merch-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0 0.15rem;
  }
  .merch-card-name {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgba(255,255,255,0.96);
    transition: color 200ms ease;
  }
  .merch-card:hover .merch-card-name,
  .merch-card:focus-visible .merch-card-name {
    color: rgba(255,255,255,1);
  }
  .merch-card-price {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: 0.86rem;
    color: rgba(255,255,255,0.55);
    font-variant-numeric: tabular-nums;
  }

  .merch-empty {
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }
  .merch-empty-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.15;
    color: rgba(255,255,255,0.92);
  }
  .merch-empty-body {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.55);
  }
  .merch-empty-note {
    margin: 0.4rem 0 0;
    font-family: "Geist", sans-serif;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.32);
  }

  .merch-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    padding: 0.85rem 1.4rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-family: "Geist", sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.95);
    text-decoration: none;
    transition: border-color 280ms ease, background 280ms ease;
  }
  .merch-cta:hover,
  .merch-cta:focus-visible {
    border-color: rgba(255,255,255,0.32);
    background: rgba(255,255,255,0.1);
  }
  .merch-cta-arrow {
    width: 15px;
    height: 15px;
  }

  .merch-foot {
    margin: clamp(3rem, 7vh, 5rem) auto 0;
    max-width: 600px;
    text-align: center;
    font-family: "Geist", sans-serif;
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.4);
  }
  .merch-foot a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.18);
    transition: color 200ms ease, border-color 200ms ease;
  }
  .merch-foot a:hover,
  .merch-foot a:focus-visible {
    color: rgba(255,255,255,0.95);
    border-color: rgba(255,255,255,0.5);
  }
</style>
