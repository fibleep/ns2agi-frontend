  }
  .engage-social:hover { transform: translateY(-2px); }
  .engage-social svg {
    width: 100%;
    height: 100%;
  }
  .engage-social:hover,
  .engage-social:focus-visible {
    color: rgba(255,255,255,1);
  }
  .engage-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    margin-top: auto;
    font-family: "Geist", sans-serif;
    font-size: 0.92rem;
    font-weight: 500;
    color: rgba(255,255,255,0.92);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.25);
    padding-bottom: 0.15rem;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .engage-cta:hover,
  .engage-cta:focus-visible {
    color: rgba(255,255,255,1);
    border-color: rgba(255,255,255,0.6);
  }
  .engage-cta-arrow {
    width: 14px;
    height: 14px;
  }

  /* ── Proof bar ── */
  .proof-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: clamp(2.5rem, 5vh, 4rem) clamp(1.5rem, 4vw, 3rem);
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    flex: 1;
    text-align: center;
  }

  .proof-val {
    font-family: "Geist", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 700;
    color: rgba(255,255,255,0.82);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .proof-key {
    font-family: "Geist", sans-serif;
    font-size: clamp(0.68rem, 1vw, 0.78rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.26);
    line-height: 1.4;
  }

  .proof-sep {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .proof-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 0;
    }
    .proof-sep {
      display: none;
    }
  }

  /* ── Scroll reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.75s cubic-bezier(0.2, 0.85, 0.25, 1),
      transform 0.75s cubic-bezier(0.2, 0.85, 0.25, 1);
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
  [data-reveal][data-reveal-delay="1"] { transition-delay: 0.12s; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 0.24s; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 0.36s; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 0.48s; }
  [data-reveal][data-reveal-delay="5"] { transition-delay: 0.6s; }

  /* ── Hero scroll pulse ── */
  @keyframes hero-scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.7; transform: scaleY(1.3); transform-origin: top; }
  }

  /* ── Flagship header ── */
  .flagship-header {
    text-align: center;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem 0;
  }
  .flagship-eyebrow {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.1;
    color: rgba(255,255,255,0.72);
  }

  /* ── Flagship grid ── */
  .flagship-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 768px) {
    .flagship-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }
  }

  /* ── The Vessel ── */
  .vessel-section {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 42vh, 420px);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
  }
  @media (min-width: 768px) {
