      border-radius: 1rem;
    }
  }
  .etoile-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 45% at 50% 50%, rgba(254,119,67,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .etoile-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem;
    gap: 0.6rem;
  }
  .etoile-title {
    margin: 0;
    font-family: "Amaranth", sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 400;
    color: #FE7743;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .etoile-desc {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.82rem, 1.2vw, 0.96rem);
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }
  .etoile-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.5rem;
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(254,119,67,0.45);
    transition: color 250ms ease, gap 250ms ease;
  }
  .etoile-content:hover .etoile-cta {
    color: rgba(254,119,67,0.8);
    gap: 0.5rem;
  }

  /* ── Stories ── */
  .stories-section {
    padding: clamp(3rem, 8vh, 7rem) 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  .stories-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .stories-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 400;
    color: rgba(255,255,255,0.88);
    line-height: 1.1;
  }
  .story-card {
