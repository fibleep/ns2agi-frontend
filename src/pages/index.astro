  /* ── Engage ── */
  .engage-section {
    padding: clamp(3rem, 6vh, 5rem) clamp(1rem, 4vw, 3rem);
    max-width: 760px;
    margin: 0 auto;
    width: 100%;
  }
  .engage-head {
    margin-bottom: clamp(1.6rem, 3.5vh, 2.4rem);
