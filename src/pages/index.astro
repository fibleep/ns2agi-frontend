---
import Layout from "../layouts/Layout.astro";
import PartnersGrid from "../components/PartnersGrid.astro";
import { blogPosts } from "../lib/blog-posts";
import { allEvents, upcomingEvents, completedEvents } from "../lib/events";
import { getEventLink } from "../lib/event-routes";
import { ArrowRight } from "lucide-react";

const upcoming = [...upcomingEvents].sort((a, b) => a.date.localeCompare(b.date));
const past = [...completedEvents].sort((a, b) => b.date.localeCompare(a.date));
const featuredPast = past.filter((e) => e.featured);

const totalEventCount = allEvents.length;

const fmtMonthYear = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { month: "short", year: "numeric" });

const fmtUpcoming = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" });

const eventHref = (e: typeof allEvents[number]) => e.link ?? getEventLink(e.id, "/commitments#events");

const isExternal = (href: string) => href.startsWith("http");

type TileSize = "default" | "feature" | "tall";
const FEATURE_IDS = new Set(["elevenlabs-hackathon-ghent", "signal-ii"]);
const TALL_IDS = new Set(["kids-ai-vibecoding-hackathon"]);
const getTileSize = (e: typeof allEvents[number]): TileSize => {
  if (FEATURE_IDS.has(e.id)) return "feature";
  if (TALL_IDS.has(e.id)) return "tall";
  return "default";
};


const commitments = [
  {
    id: "events",
    label: "Events",
    sub: "Hackathons & meetups",
    href: "/commitments#events",
    image: "/ai-hackathon-ii/4.jpg",
  },
  {
    id: "education",
    label: "Education",
    sub: "Workshops & lectures",
    href: "/commitments#education",
    image: "/kids-hackathon/photo_2026-02-26 15.57.18.jpeg",
  },
  {
    id: "engineering",
    label: "Engineering",
    sub: "Projects & products",
    href: "/commitments#engineering",
    image: "/misc/photo_2026-03-08 22.06.11.jpeg",
  },
  {
    id: "ecosystem",
    label: "Ecosystem",
    sub: "Partners & connections",
    href: "/commitments#ecosystem",
    image: "/elevenlabs/5.jpg",
  },
];
---

<Layout>

  <!-- Identity block — compact -->
  <section class="id-hero">
    <img src="/nsstar-clean.svg" alt="North Star" class="id-star" data-id-star />
    <p class="id-wordmark">NORTH&nbsp;STAR</p>
    <p class="id-tagline">Building Europe's AI &amp; Robotics future</p>
  </section>

  <!-- Asymmetric commitment bento -->
  <div class="cp-bento">
    {commitments.map((c, i) => (
      <a href={c.href} class={`cp-panel cp-panel-${c.id}`} style={`--panel-i: ${i}`}>
        <img src={c.image} alt="" loading="lazy" class="cp-img" />
        <div class="cp-shade"></div>
        <div class="cp-text">
          <p class="cp-label">{c.label}</p>
          <p class="cp-sub">{c.sub}</p>
        </div>
        <div class="cp-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </a>
    ))}
  </div>

  <!-- Engage -->
  <section class="engage-section" data-reveal>
    <div class="engage-head">
      <h2 class="engage-title">Engage</h2>
    </div>
    <div class="engage-grid">
      <article class="engage-card" id="newsletter">
        <div class="engage-newsletter">
          <script src="https://etoile.events/embed/newsletter-widget?org=north-star&color=%23000000&placeholder=polaris%40ns2agi.com&button=Subscribe" async></script>
        </div>
      </article>

      <article class="engage-card">
        <nav class="engage-socials" aria-label="Social links">
          <a href="https://www.linkedin.com/company/north-star-agi" target="_blank" rel="noopener noreferrer" class="engage-social" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/ns2agi" target="_blank" rel="noopener noreferrer" class="engage-social" aria-label="X">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer" class="engage-social" aria-label="Discord">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419-.0188 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
          </a>
          <a href="https://www.instagram.com/northstaragi/" target="_blank" rel="noopener noreferrer" class="engage-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          {/* TODO: replace with real WhatsApp community invite URL */}
          <a href="https://chat.whatsapp.com/" target="_blank" rel="noopener noreferrer" class="engage-social" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.69 5.523l-.999 3.648 3.798-.97zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          </a>
        </nav>
      </article>

      <article class="engage-card">
        <a href="https://atlas.ns2agi.com" target="_blank" rel="noopener noreferrer" class="engage-cta">
          Become a member <ArrowRight className="engage-cta-arrow" />
        </a>
      </article>
    </div>
  </section>

  <!-- Upcoming events -->
  <section class="up-section" data-reveal>
    <div class="up-head">
      <h2 class="up-title">Upcoming</h2>
    </div>
    <div class="up-grid">
      <a href="/vessel" class="up-card">
        <div class="up-thumb" style={`--thumb-bg: url('/blogs/the-vessel/2026-03-10 16.58.10.jpg')`}>
          <img src="/blogs/the-vessel/2026-03-10 16.58.10.jpg" alt="" loading="lazy" />
        </div>
        <div class="up-body">
          <span class="up-date">Every Thu &amp; Sat &middot; Open Lab</span>
          <h3 class="up-card-title">OpenLab @ The Vessel</h3>
          <p class="up-desc">Visit our open lab in AI &amp; Robotics, build your own project or help us with our engineering initiatives.</p>
        </div>
      </a>
      {upcoming.map((event) => {
        const href = eventHref(event);
        const ext = isExternal(href);
        return (
          <a
            href={href}
            class="up-card"
            target={ext ? "_blank" : undefined}
            rel={ext ? "noopener noreferrer" : undefined}
          >
            <div class="up-thumb" style={`--thumb-bg: url('${event.thumbnail}')`}>
              <img src={event.thumbnail} alt="" loading="lazy" />
            </div>
            <div class="up-body">
              <span class="up-date">{fmtUpcoming(event.date)}</span>
              <h3 class="up-card-title">{event.title}</h3>
              <p class="up-desc">{event.description}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Past events bento -->
  <section class="past-section" data-reveal>
    <div class="past-head">
      <h2 class="past-title">Where we&rsquo;ve been</h2>
    </div>
    <div class="past-bento-wrap">
      <div class="past-bento">
        {featuredPast.map((event) => {
          const href = eventHref(event);
          const ext = isExternal(href);
          const size = getTileSize(event);
          return (
            <a
              href={href}
              class={`past-tile size-${size}`}
              target={ext ? "_blank" : undefined}
              rel={ext ? "noopener noreferrer" : undefined}
            >
              <img src={event.thumbnail} alt="" loading="lazy" />
              <div class="past-tile-shade"></div>
              <div class="past-tile-info">
                <span class="past-tile-date">{fmtMonthYear(event.date)}</span>
                <h3 class="past-tile-name">{event.title}</h3>
              </div>
            </a>
          );
        })}
      </div>
      <div class="past-fade" aria-hidden="true"></div>
    </div>
    <div class="past-cta-wrap">
      <a href="/events" class="past-cta">
        Show all {totalEventCount} events <ArrowRight className="past-cta-arrow" />
      </a>
    </div>
  </section>

  <!-- Scene: Flagship Initiatives -->
  <div class="flagship-grid">
    <!-- The Vessel -->
    <section class="vessel-section" data-reveal>
      <div class="vessel-bg" aria-hidden="true">
        <img src="/thevessel.png" alt="" loading="lazy" />
      </div>
      <div class="vessel-gradient-b" aria-hidden="true"></div>
      <div class="vessel-gradient-r" aria-hidden="true"></div>
      <div class="vessel-vignette" aria-hidden="true"></div>
      <a href="/vessel" class="vessel-content">
        <h3 class="vessel-title"><img src="/vessel/vessel-logo-trim.png" alt="The Vessel" class="vessel-logo-img" /></h3>
        <p class="vessel-desc">An atelier for intelligent machines</p>
        <span class="vessel-cta">Visit <ArrowRight className="w-3 h-3" /></span>
        <div class="vessel-supporter">
          <span class="vessel-supporter-label">Supported by</span>
          <img src="/partnerships/workedwith/17.png" alt="Port of Antwerp-Bruges" class="vessel-supporter-logo" />
        </div>
      </a>
    </section>

    <!-- Etoile -->
    <section class="etoile-section" data-reveal>
      <div class="etoile-glow" aria-hidden="true"></div>
      <a href="https://etoile.events" target="_blank" rel="noopener noreferrer" class="etoile-content">
        <h3 class="etoile-title">etoile</h3>
        <p class="etoile-desc">Community management and event platform</p>
        <span class="etoile-cta">Explore <ArrowRight className="w-3 h-3" /></span>
      </a>
    </section>
  </div>

  <!-- Scene 5: Stories -->
  <section class="stories-section">
    <div class="stories-header" data-reveal>
      <h2 class="stories-title">Stories</h2>
    </div>
    <div class="stories-list">
      {blogPosts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class="story-card"
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          <div class="story-card-inner">
            <div class="story-card-text">
              <p class="story-card-meta">
                {post.author}&nbsp;&middot;&nbsp;{post.date}&nbsp;&middot;&nbsp;{post.readTime}
              </p>
              <h3 class="story-card-title">{post.title}</h3>
              <p class="story-card-excerpt">{post.excerpt}</p>
              <span class="story-card-cta">
                Read <ArrowRight className="w-3.5 h-3.5" />
              </span>
            </div>
            <div class="story-card-image-wrap">
              <img src={post.thumbnail} alt="" class="story-card-image" loading="lazy" />
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <PartnersGrid />

  <!-- Scene 7: Close -->
  <section class="home-close" data-reveal>
    <img src="/nsstar-clean.svg" alt="" class="home-close-star" />
    <p class="home-close-cta">Let's build it together</p>
    <nav class="home-close-socials" aria-label="Social links">
      <a href="https://www.linkedin.com/company/north-star-agi" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://x.com/ns2agi" target="_blank" rel="noopener noreferrer">X</a>
      <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer">Discord</a>
      <a href="https://www.instagram.com/northstaragi/" target="_blank" rel="noopener noreferrer">Instagram</a>
    </nav>
  </section>

</Layout>

<script is:inline>
  /* Scroll reveal */
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-revealed");
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => {
    revealObserver.observe(el);
  });

  /* Dock nav logo once the hero star scrolls out of view */
  const idStar = document.querySelector("[data-id-star]");
  if (idStar) {
    let docked = false;
    const sync = (d) => {
      if (docked === d) return;
      docked = d;
      window.dispatchEvent(new CustomEvent("ns:star-dock", { detail: { docked: d } }));
    };
    new IntersectionObserver(
      ([e]) => sync(!e.isIntersecting),
      { threshold: 0, rootMargin: "-56px 0px 0px 0px" }
    ).observe(idStar);
  }

</script>

<style is:global>
  /* ── Identity block ── */
  .id-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    padding: clamp(3rem, 7vh, 5rem) 1.5rem clamp(2.5rem, 5vh, 4rem);
  }

  /* Ambient glow behind hero */
  .id-hero::before {
    content: '';
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (max-width: 520px) {
    .id-hero {
      padding-top: clamp(6rem, 16vh, 10rem);
      padding-bottom: clamp(2rem, 4vh, 3rem);
    }
  }

  .id-star {
    width: clamp(48px, 8vw, 72px);
    height: auto;
    display: block;
    filter: drop-shadow(0 0 18px rgba(255,255,255,0.08));
    opacity: 0;
    animation: id-star-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  @keyframes id-star-in {
    from { opacity: 0; transform: scale(0.5) rotate(-45deg); }
    to   { opacity: 0.82; transform: scale(1) rotate(0deg); }
  }

  .id-wordmark {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(1.2rem, 3vw, 2.2rem);
    letter-spacing: 0.38em;
    font-weight: 700;
    color: rgba(255,255,255,0.62);
    line-height: 1;
    opacity: 0;
    animation: id-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .id-tagline {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.05rem, 3vw, 1.4rem);
    color: rgba(255,255,255,0.28);
    line-height: 1;
    opacity: 0;
    animation: id-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  @keyframes id-fade-up {
    from { opacity: 0; transform: translateY(16px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  /* ── Asymmetric commitment bento ── */
  .cp-bento {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    grid-template-rows: 1fr 1fr 0.7fr;
    gap: 0.5rem;
    padding: 0 clamp(1rem, 4vw, 3rem);
    max-width: 920px;
    margin: 0 auto clamp(2rem, 4vh, 3.5rem);
  }

  /* Events: tall card spanning 2 rows on the left */
  .cp-panel-events {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  /* Education: top right */
  .cp-panel-education {
    grid-column: 2;
    grid-row: 1;
  }

  /* Engineering: mid right */
  .cp-panel-engineering {
    grid-column: 2;
    grid-row: 2;
  }

  /* Ecosystem: wide card spanning full width */
  .cp-panel-ecosystem {
    grid-column: 1 / -1;
    grid-row: 3;
  }

  .cp-panel {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    text-decoration: none;
    display: block;
    min-height: 180px;
    opacity: 0;
    animation: cp-panel-in 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.5s + var(--panel-i, 0) * 0.12s);
  }

  @keyframes cp-panel-in {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .cp-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.58) saturate(0.75);
    transition: filter 500ms ease;
  }

  .cp-panel:hover .cp-img {
    filter: brightness(0.72) saturate(0.88);
  }

  /* Per-panel image focus points */
  .cp-panel-education .cp-img {
    object-position: 65% center;
  }

  .cp-panel-engineering .cp-img {
    object-position: 40% 30%;
  }

  .cp-panel-ecosystem .cp-img {
    object-position: center 40%;
  }

  .cp-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.72) 0%,
      rgba(0,0,0,0.25) 45%,
      rgba(0,0,0,0.05) 100%
    );
    transition: opacity 400ms ease;
  }

  .cp-panel:hover .cp-shade {
    opacity: 0.7;
  }

  .cp-text {
    position: absolute;
    bottom: 1.2rem;
    left: 1.3rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .cp-index {
    font-family: "Geist", sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.28);
    line-height: 1;
    margin-bottom: 0.15rem;
  }

  .cp-label {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    color: rgba(255,255,255,0.92);
    line-height: 1;
    transition: color 300ms ease;
  }

  .cp-panel:hover .cp-label {
    color: rgba(255,255,255,1);
  }

  .cp-sub {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.72rem, 1.1vw, 0.85rem);
    color: rgba(255,255,255,0.4);
