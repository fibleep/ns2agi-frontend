      border-radius: 1rem;
    }
  }
  .vessel-bg {
    position: absolute;
    inset: 0;
  }
  .vessel-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
  }
  .vessel-gradient-b {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-gradient-r {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 35% 35% at 50% 40%, transparent 0%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem;
    gap: 0.6rem;
  }
  .vessel-title {
    margin: 0;
    line-height: 0;
  }
  .vessel-logo-img {
    width: clamp(220px, 28vw, 320px);
