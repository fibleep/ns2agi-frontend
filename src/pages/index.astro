  }

  /* Arrow indicator */
  .cp-arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    color: rgba(255,255,255,0.18);
    transition: color 300ms ease, transform 300ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }

  .cp-panel:hover .cp-arrow {
    color: rgba(255,255,255,0.55);
    transform: translate(2px, -2px);
  }

  @media (max-width: 600px) {
    .cp-bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 0.4rem;
      padding: 0 0.6rem;
      margin-bottom: clamp(6rem, 14vh, 10rem);
