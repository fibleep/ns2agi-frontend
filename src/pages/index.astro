    color: rgba(255,255,255,0.42);
    max-width: 50ch;
  }
  .story-card-cta {
    margin-top: 0.35rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Geist", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.42);
    transition: color 240ms ease, gap 240ms ease;
  }
  .story-card:hover .story-card-cta {
    color: rgba(255,255,255,0.72);
    gap: 0.6rem;
  }
  .story-card-image-wrap {
