    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.6));
    transition: transform 300ms ease;
  }
  .vessel-content:hover .vessel-logo-img {
    transform: translateY(-2px);
  }
  .vessel-desc {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.82rem, 1.2vw, 0.96rem);
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }
  .vessel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.5rem;
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    transition: color 250ms ease, gap 250ms ease;
  }
  .vessel-content:hover .vessel-cta {
    color: rgba(255,255,255,0.65);
    gap: 0.5rem;
  }
  .vessel-supporter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .vessel-supporter-label {
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
  }
  .vessel-supporter-logo {
    height: clamp(1.6rem, 3vw, 2.2rem);
    width: auto;
    object-fit: contain;
    opacity: 0.85;
  }

  /* ── Etoile ── */
  .etoile-section {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 42vh, 420px);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
  }
  @media (min-width: 768px) {
