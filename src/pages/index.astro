---
import Layout from "../layouts/Layout.astro";
import HorizontalTimeline from "../components/horizontal-timeline";
import PartnersGrid from "../components/PartnersGrid.astro";
import { allEvents } from "../lib/events";
import { blogPosts } from "../lib/blog-posts";
import { ArrowRight } from "lucide-react";

const commitments = [
  {
    id: "events",
    label: "Events",
    sub: "Hackathons & meetups",
    href: "/commitments#events",
    image: "/ai-hackathon-ii/4.jpg",
  },
  {
    id: "education",
    label: "Education",
    sub: "Workshops & lectures",
    href: "/commitments#education",
    image: "/kids-hackathon/photo_2026-02-26 15.57.18.jpeg",
  },
  {
    id: "engineering",
    label: "Engineering",
    sub: "Projects & products",
    href: "/commitments#engineering",
    image: "/misc/photo_2026-03-08 22.06.11.jpeg",
  },
  {
    id: "ecosystem",
    label: "Ecosystem",
    sub: "Partners & connections",
    href: "/commitments#ecosystem",
    image: "/elevenlabs/5.jpg",
  },
];
---

<Layout>

  <!-- Identity block — compact -->
  <section class="id-hero">
    <img src="/nsstar-clean.svg" alt="North Star" class="id-star" data-id-star />
    <p class="id-wordmark">NORTH&nbsp;STAR</p>
    <p class="id-tagline">Building Belgium's AI &amp; Robotics Future</p>
  </section>

  <!-- Asymmetric commitment bento -->
  <div class="cp-bento">
    {commitments.map((c, i) => (
      <a href={c.href} class={`cp-panel cp-panel-${c.id}`} style={`--panel-i: ${i}`}>
        <img src={c.image} alt="" loading="lazy" class="cp-img" />
        <div class="cp-shade"></div>
        <div class="cp-text">
          <span class="cp-index">0{i + 1}</span>
          <p class="cp-label">{c.label}</p>
          <p class="cp-sub">{c.sub}</p>
        </div>
        <div class="cp-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </a>
    ))}
  </div>

  <!-- Donate strip -->
  <div class="donate-strip" data-reveal>
    <a href="https://www.weglow.world/o/northstaragi/donate" target="_blank" rel="noopener noreferrer" class="donate-link">
      Support our mission
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>

  <!-- Our Events timeline -->
  <section class="timeline-endcap" data-reveal>
    <p class="timeline-endcap-label">Our events</p>
    <div class="timeline-endcap-scroll">
      <HorizontalTimeline client:load events={allEvents} initialScrollTarget="end" compact />
    </div>
  </section>

  <!-- Scene: Flagship Initiatives -->
  <div class="flagship-header" data-reveal>
    <span class="flagship-eyebrow">Flagship Initiatives</span>
  </div>

  <!-- The Vessel -->
  <section class="vessel-section" data-reveal>
    <div class="vessel-bg" aria-hidden="true">
      <img src="/thevessel.png" alt="" loading="lazy" />
    </div>
    <div class="vessel-gradient-b" aria-hidden="true"></div>
    <div class="vessel-gradient-r" aria-hidden="true"></div>
    <div class="vessel-vignette" aria-hidden="true"></div>
    <a href="/blog/the-vessel" class="vessel-content">
      <h3 class="vessel-title">The Vessel</h3>
      <p class="vessel-desc">An atelier for intelligent machines</p>
      <span class="vessel-cta">Visit <ArrowRight className="w-3 h-3" /></span>
      <div class="vessel-supporter">
        <span class="vessel-supporter-label">Supported by</span>
        <img src="/partnerships/workedwith/17.png" alt="Port of Antwerp-Bruges" class="vessel-supporter-logo" />
      </div>
    </a>
  </section>

  <!-- Etoile -->
  <section class="etoile-section" data-reveal>
    <div class="etoile-glow" aria-hidden="true"></div>
    <a href="https://etoile.events" target="_blank" rel="noopener noreferrer" class="etoile-content">
      <h3 class="etoile-title">etoile</h3>
      <p class="etoile-desc">Community management and event platform</p>
      <span class="etoile-cta">Explore <ArrowRight className="w-3 h-3" /></span>
    </a>
  </section>

  <!-- Scene 5: Stories -->
  <section class="stories-section">
    <div class="stories-header" data-reveal>
      <h2 class="stories-title">Stories</h2>
    </div>
    <div class="stories-list">
      {blogPosts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class="story-card"
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          <div class="story-card-inner">
            <div class="story-card-text">
              <p class="story-card-meta">
                {post.author}&nbsp;&middot;&nbsp;{post.date}&nbsp;&middot;&nbsp;{post.readTime}
              </p>
              <h3 class="story-card-title">{post.title}</h3>
              <p class="story-card-excerpt">{post.excerpt}</p>
              <span class="story-card-cta">
                Read <ArrowRight className="w-3.5 h-3.5" />
              </span>
            </div>
            <div class="story-card-image-wrap">
              <img src={post.thumbnail} alt="" class="story-card-image" loading="lazy" />
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <PartnersGrid />

  <!-- Scene 7: Close -->
  <section class="home-close" data-reveal>
    <img src="/nsstar-clean.svg" alt="" class="home-close-star" />
    <p class="home-close-cta">Let's build it together</p>
    <nav class="home-close-socials" aria-label="Social links">
      <a href="https://www.linkedin.com/company/north-star-agi" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://x.com/ns2agi" target="_blank" rel="noopener noreferrer">X</a>
      <a href="https://discord.gg/m5Hknymurb" target="_blank" rel="noopener noreferrer">Discord</a>
      <a href="https://www.instagram.com/northstaragi/" target="_blank" rel="noopener noreferrer">Instagram</a>
    </nav>
  </section>

</Layout>

<script is:inline>
  /* Scroll reveal */
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-revealed");
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => {
    revealObserver.observe(el);
  });

  /* Dock nav logo once the hero star scrolls out of view */
  const idStar = document.querySelector("[data-id-star]");
  if (idStar) {
    let docked = false;
    const sync = (d) => {
      if (docked === d) return;
      docked = d;
      window.dispatchEvent(new CustomEvent("ns:star-dock", { detail: { docked: d } }));
    };
    new IntersectionObserver(
      ([e]) => sync(!e.isIntersecting),
      { threshold: 0, rootMargin: "-56px 0px 0px 0px" }
    ).observe(idStar);
  }

  /* Timeline: always start scrolled to newest (rightmost) end */
  function scrollTimelineToEnd() {
    var c = document.querySelector('.horizontal-timeline-scroll');
    if (c && c.scrollWidth > c.clientWidth) {
      c.scrollLeft = c.scrollWidth - c.clientWidth;
    }
  }
  scrollTimelineToEnd();
  requestAnimationFrame(scrollTimelineToEnd);
  setTimeout(scrollTimelineToEnd, 300);
</script>

<style is:global>
  /* ── Identity block ── */
  .id-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    padding: clamp(3rem, 7vh, 5rem) 1.5rem clamp(2.5rem, 5vh, 4rem);
  }

  /* Ambient glow behind hero */
  .id-hero::before {
    content: '';
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (max-width: 520px) {
    .id-hero {
      padding-top: clamp(6rem, 16vh, 10rem);
      padding-bottom: clamp(2rem, 4vh, 3rem);
    }
  }

  .id-star {
    width: clamp(48px, 8vw, 72px);
    height: auto;
    display: block;
    filter: drop-shadow(0 0 18px rgba(255,255,255,0.08));
    opacity: 0;
    animation: id-star-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  @keyframes id-star-in {
    from { opacity: 0; transform: scale(0.5) rotate(-45deg); }
    to   { opacity: 0.82; transform: scale(1) rotate(0deg); }
  }

  .id-wordmark {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(1.2rem, 3vw, 2.2rem);
    letter-spacing: 0.38em;
    font-weight: 700;
    color: rgba(255,255,255,0.62);
    line-height: 1;
    opacity: 0;
    animation: id-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .id-tagline {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.05rem, 3vw, 1.4rem);
    color: rgba(255,255,255,0.28);
    line-height: 1;
    opacity: 0;
    animation: id-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  @keyframes id-fade-up {
    from { opacity: 0; transform: translateY(16px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  /* ── Asymmetric commitment bento ── */
  .cp-bento {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    grid-template-rows: 1fr 1fr 0.7fr;
    gap: 0.5rem;
    padding: 0 clamp(1rem, 4vw, 3rem);
    max-width: 920px;
    margin: 0 auto clamp(2rem, 4vh, 3.5rem);
  }

  /* Events: tall card spanning 2 rows on the left */
  .cp-panel-events {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  /* Education: top right */
  .cp-panel-education {
    grid-column: 2;
    grid-row: 1;
  }

  /* Engineering: mid right */
  .cp-panel-engineering {
    grid-column: 2;
    grid-row: 2;
  }

  /* Ecosystem: wide card spanning full width */
  .cp-panel-ecosystem {
    grid-column: 1 / -1;
    grid-row: 3;
  }

  .cp-panel {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    text-decoration: none;
    display: block;
    min-height: 180px;
    opacity: 0;
    animation: cp-panel-in 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.5s + var(--panel-i, 0) * 0.12s);
  }

  @keyframes cp-panel-in {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .cp-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.58) saturate(0.75);
    transform: scale(1.06);
    transition: transform 600ms cubic-bezier(0.2, 0.85, 0.25, 1), filter 500ms ease;
  }

  .cp-panel:hover .cp-img {
    transform: scale(1);
    filter: brightness(0.72) saturate(0.88);
  }

  /* Per-panel image focus points */
  .cp-panel-education .cp-img {
    object-position: 65% center;
  }

  .cp-panel-engineering .cp-img {
    object-position: 40% 30%;
  }

  .cp-panel-ecosystem .cp-img {
    object-position: center 40%;
  }

  .cp-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.72) 0%,
      rgba(0,0,0,0.25) 45%,
      rgba(0,0,0,0.05) 100%
    );
    transition: opacity 400ms ease;
  }

  .cp-panel:hover .cp-shade {
    opacity: 0.7;
  }

  .cp-text {
    position: absolute;
    bottom: 1.2rem;
    left: 1.3rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .cp-index {
    font-family: "Geist", sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.28);
    line-height: 1;
    margin-bottom: 0.15rem;
  }

  .cp-label {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    color: rgba(255,255,255,0.92);
    line-height: 1;
    transition: color 300ms ease;
  }

  .cp-panel:hover .cp-label {
    color: rgba(255,255,255,1);
  }

  .cp-sub {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.72rem, 1.1vw, 0.85rem);
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 300ms ease;
  }

  .cp-panel:hover .cp-sub {
    color: rgba(255,255,255,0.58);
  }

  /* Arrow indicator */
  .cp-arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    color: rgba(255,255,255,0.18);
    transition: color 300ms ease, transform 300ms cubic-bezier(0.2, 0.85, 0.25, 1);
  }

  .cp-panel:hover .cp-arrow {
    color: rgba(255,255,255,0.55);
    transform: translate(2px, -2px);
  }

  @media (max-width: 600px) {
    .cp-bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 0.4rem;
      padding: 0 0.6rem;
      margin-bottom: clamp(6rem, 14vh, 10rem);
    }
    .cp-panel-events,
    .cp-panel-education,
    .cp-panel-engineering,
    .cp-panel-ecosystem {
      grid-column: 1;
      grid-row: auto;
    }
    .cp-panel {
      min-height: 200px;
      border-radius: 0.75rem;
    }
    .cp-label { font-size: clamp(1.3rem, 6vw, 1.8rem); }
  }

  /* ── Donate strip ── */
  .donate-strip {
    text-align: center;
    padding: clamp(1.5rem, 3vh, 2.5rem) 1.5rem;
  }

  .donate-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 9999px;
    transition: color 250ms ease, border-color 250ms ease, gap 250ms ease;
  }

  .donate-link:hover {
    color: rgba(255,255,255,0.62);
    border-color: rgba(255,255,255,0.18);
    gap: 0.55rem;
  }

  /* ── Proof bar ── */
  .proof-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: clamp(2.5rem, 5vh, 4rem) clamp(1.5rem, 4vw, 3rem);
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    flex: 1;
    text-align: center;
  }

  .proof-val {
    font-family: "Geist", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 700;
    color: rgba(255,255,255,0.82);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .proof-key {
    font-family: "Geist", sans-serif;
    font-size: clamp(0.68rem, 1vw, 0.78rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.26);
    line-height: 1.4;
  }

  .proof-sep {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .proof-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 0;
    }
    .proof-sep {
      display: none;
    }
  }

  /* ── Scroll reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.75s cubic-bezier(0.2, 0.85, 0.25, 1),
      transform 0.75s cubic-bezier(0.2, 0.85, 0.25, 1);
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
  [data-reveal][data-reveal-delay="1"] { transition-delay: 0.12s; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 0.24s; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 0.36s; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 0.48s; }
  [data-reveal][data-reveal-delay="5"] { transition-delay: 0.6s; }

  /* ── Hero scroll pulse ── */
  @keyframes hero-scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.7; transform: scaleY(1.3); transform-origin: top; }
  }

  /* ── Flagship header ── */
  .flagship-header {
    text-align: center;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem 0;
  }
  .flagship-eyebrow {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.1;
    color: rgba(255,255,255,0.72);
  }

  /* ── The Vessel ── */
  .vessel-section {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 42vh, 420px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vessel-bg {
    position: absolute;
    inset: 0;
  }
  .vessel-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
  }
  .vessel-gradient-b {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-gradient-r {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--offblack) 0%, transparent 30%, transparent 70%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 35% 35% at 50% 40%, transparent 0%, var(--offblack) 100%);
    pointer-events: none;
  }
  .vessel-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem;
    gap: 0.6rem;
  }
  .vessel-title {
    margin: 0;
    font-family: "Cormorant", serif;
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.9);
    line-height: 1;
  }
  .vessel-desc {
    margin: 0;
    font-family: "Geist", sans-serif;
    font-size: clamp(0.82rem, 1.2vw, 0.96rem);
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }
  .vessel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.5rem;
    font-family: "Geist", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    transition: color 250ms ease, gap 250ms ease;
  }
  .vessel-content:hover .vessel-cta {
    color: rgba(255,255,255,0.65);
    gap: 0.5rem;
  }
  .vessel-content:hover .vessel-title {
    color: rgba(255,255,255,1);
  }
  .vessel-supporter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .vessel-supporter-label {
    font-family: "Geist", sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
  }
  .vessel-supporter-logo {
    height: clamp(1.6rem, 3vw, 2.2rem);
    width: auto;
    object-fit: contain;
    opacity: 0.85;
  }

  /* ── Etoile ── */
  .etoile-section {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 42vh, 420px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .etoile-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 45% at 50% 50%, rgba(254,119,67,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .etoile-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: clamp(3rem, 6vh, 5rem) 1.5rem;
    gap: 0.6rem;
  }
  .etoile-title {
    margin: 0;
    font-family: "Amaranth", sans-serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400;
    color: #FE7743;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .etoile-desc {
    margin: 0;
    font-family: "Geist", sans-serif;
